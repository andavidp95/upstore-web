---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import SEO from '../../components/SEO/SEO.astro';
import GlobalNavbar from '../../components/GlobalNavbar.astro';
import GlobalFooter from '../../components/GlobalFooter.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const upstoreProducts = await getCollection('equipos');
  return upstoreProducts.map((p) => ({
    params: { slug: p.slug },
    props: { product: { ...p.data, slug: p.slug } },
  }));
}

const { product } = Astro.props;
if (!product) { return Astro.redirect('/'); }

const categoryConfig = {
  'MINI_UPS': { name: 'Mini UPS', icon: '🔌' },
  'MONOFASICO': { name: 'Monofásico', icon: '⚡' },
  'BIFASICO': { name: 'Bifásico', icon: '⚡⚡' },
  'TRIFASICO': { name: 'Trifásico', icon: '⚡⚡⚡' }
};

const brandConfig = {
  'APC': { name: 'APC', color: 'bg-red-100 text-red-700 border-red-200' },
  'VERTIV': { name: 'Vertiv', color: 'bg-blue-100 text-blue-700 border-blue-200' },
  'EATON': { name: 'Eaton', color: 'bg-yellow-100 text-yellow-700 border-yellow-200' },
  'VICTRON': { name: 'Victron', color: 'bg-cyan-100 text-cyan-700 border-cyan-200' },
  'OTROS': { name: 'Otros', color: 'bg-gray-100 text-gray-600 border-gray-200' }
};

const getStatusConfig = (status) => {
  switch (status) {
    case 'STOCK': return { class: 'bg-green-50 text-green-700 border-green-200', text: 'Disponible', btnClass: 'bg-green-600 hover:bg-green-700', btnText: 'Comprar Ahora' };
    case 'PREVENTA': return { class: 'bg-blue-50 text-blue-700 border-blue-200', text: 'Preventa', btnClass: 'bg-blue-600 hover:bg-blue-700', btnText: 'Reservar ahora' };
    case 'POR_LLEGAR': return { class: 'bg-purple-50 text-purple-700 border-purple-200', text: 'Por llegar', btnClass: 'bg-purple-600 hover:bg-purple-700', btnText: 'Reservar ahora' };
    case 'BAJO_PEDIDO': return { class: 'bg-gray-100 text-gray-600 border-gray-200', text: 'Bajo pedido', btnClass: 'bg-gray-700 hover:bg-gray-800', btnText: 'Pedir ahora' };
    default: return { class: 'bg-gray-100 text-gray-500 border-gray-200', text: status, btnClass: 'bg-gray-600 hover:bg-gray-700', btnText: 'Consultar' };
  }
};

const statusInfo = getStatusConfig(product.status);
const brandBadge = brandConfig[product.brand] || brandConfig['OTROS'];
const catConfig = categoryConfig[product.category] || { name: product.category, icon: '' };
const canonicalUrl = `${import.meta.env.PUBLIC_SITE_URL || 'https://upstore.com.ec'}/producto/${product.slug}`;
---

<Layout title={`${product.name} | UPStore Ecuador`}>
  <SEO
    pageType="product"
    title={`${product.name} | UPStore Ecuador`}
    description={product.description.substring(0, 150) + '...'}
    canonical={canonicalUrl}
  />

  <GlobalNavbar />

  <main class="pt-20 pb-16 min-h-screen bg-[#f8f9fb] dark:bg-[#0f1117] transition-colors duration-500">
    <div class="container mx-auto px-4 max-w-6xl">

      <a href="/" class="inline-flex items-center text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white font-medium mb-6 transition-colors">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Volver al Catálogo
      </a>

      <div class="bg-white dark:bg-[#181b25] rounded-2xl border border-gray-100 dark:border-white/5 overflow-hidden flex flex-col md:flex-row transition-colors duration-500">

        <div class="md:w-1/2 p-0 flex justify-center items-center bg-gray-50 dark:bg-white/[0.02] relative overflow-hidden min-h-[300px] md:min-h-[500px]">
          <img
            src={product.imageUrl}
            alt={product.name}
            class="w-full h-auto max-h-[500px] object-contain p-6 relative z-10"
            oncontextmenu="return false;"
            draggable="false"
          />
          <div class="absolute top-4 left-4 z-20">
            <span class={`text-[11px] font-medium px-2.5 py-1 rounded border ${brandBadge.class}`}>
              {brandBadge.name}
            </span>
          </div>
          <div class="absolute top-4 right-4 z-20">
            <span class={`text-[11px] font-medium px-2.5 py-1 rounded border ${statusInfo.class}`}>
              {statusInfo.text}
            </span>
          </div>
        </div>

        <div class="md:w-1/2 p-6 lg:p-8 border-t md:border-t-0 md:border-l border-gray-100 dark:border-white/5 flex flex-col">

          <div class="flex items-center gap-2 mb-3">
            <span class="text-xs text-gray-400 dark:text-gray-500">{catConfig.icon} {catConfig.name}</span>
            {product.capacity && product.capacity !== 'OTRO' && (
              <>
                <span class="text-gray-300 dark:text-gray-600">·</span>
                <span class="text-xs text-gray-400 dark:text-gray-500">{product.capacity}</span>
              </>
            )}
            {product.voltage && (
              <>
                <span class="text-gray-300 dark:text-gray-600">·</span>
                <span class="text-xs text-gray-400 dark:text-gray-500">{product.voltage}</span>
              </>
            )}
            {product.formFactor && product.formFactor !== 'OTRO' && (
              <>
                <span class="text-gray-300 dark:text-gray-600">·</span>
                <span class="text-xs text-gray-400 dark:text-gray-500">{product.formFactor === 'AMBOS' ? 'Rack/Torre' : product.formFactor}</span>
              </>
            )}
          </div>

          <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 dark:text-white mb-4 leading-tight transition-colors">
            {product.name}
          </h1>

          <div class="mb-6">
            <span class="text-3xl font-extrabold text-gray-900 dark:text-white">${Number(product.price).toFixed(2)}</span>
            <span class="text-sm text-gray-400 ml-2">IVA incluido</span>
          </div>

          <div class="prose prose-sm max-w-none text-gray-600 dark:text-gray-300 whitespace-pre-line mb-6 leading-relaxed">
            {product.description}
          </div>

          {product.productLink && (
            <a
              href={product.productLink}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center text-sm text-blue-600 hover:text-blue-700 font-medium mb-6 transition-colors"
            >
              <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              Ver ficha técnica del fabricante
            </a>
          )}

          <div class="mt-auto pt-4 border-t border-gray-100 dark:border-gray-700">
            <button
              class={`w-full ${statusInfo.btnClass} text-white text-base font-semibold py-3 px-6 rounded-lg transition-all duration-200 hover:shadow-lg flex items-center justify-center`}
              onclick={`contactProduct('${encodeURIComponent(product.name)}', '${product.price}', '${product.status}')`}
            >
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/></svg>
              {statusInfo.btnText}
            </button>
            <p class="text-center text-xs text-gray-400 mt-3">Te responderemos por WhatsApp a la brevedad</p>
          </div>

          <div class="flex justify-center items-center gap-5 mt-4 pt-4 border-t border-gray-100 dark:border-white/5">
            <div class="flex items-center gap-1.5">
              <img src="/images/trust/payphone.svg" alt="Payphone" class="h-5 object-contain opacity-60 dark:opacity-40" onerror="this.style.display='none'">
              <span class="text-[10px] text-gray-400 dark:text-gray-500">Payphone</span>
            </div>
            <div class="flex items-center gap-1.5">
              <img src="/images/trust/servientrega.svg" alt="Servientrega" class="h-5 object-contain opacity-60 dark:opacity-40" onerror="this.style.display='none'">
              <span class="text-[10px] text-gray-400 dark:text-gray-500">Servientrega</span>
            </div>
          </div>

        </div>
      </div>
    </div>
  </main>

  <GlobalFooter />
</Layout>

<script>
  const WHATSAPP_NUMBER = '593987799459';

  window.contactProduct = function(productNameEnc, price, status) {
    const productName = decodeURIComponent(productNameEnc);
    let actionWord = "comprar";
    if (status === 'BAJO_PEDIDO') actionWord = "cotizar";
    if (status === 'PREVENTA' || status === 'POR_LLEGAR') actionWord = "reservar";
    const message = `¡Hola! Me interesa ${actionWord} este UPS: ${productName} (Precio ref: $${price}). ¿Podrían ayudarme con el proceso?`;
    window.open(`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`, '_blank');
  };
</script>
