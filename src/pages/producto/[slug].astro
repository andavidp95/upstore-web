---
export const prerender = true; 

import Layout from '../../layouts/Layout.astro';
import SEO from '../../components/SEO/SEO.astro';
import GlobalNavbar from '../../components/GlobalNavbar.astro';
import GlobalFooter from '../../components/GlobalFooter.astro';
import { getCollection } from 'astro:content';

// 1. Generar Slugs estáticos leyendo los archivos Markdown
export async function getStaticPaths() {
  const upstoreProducts = await getCollection('equipos');
  
  return upstoreProducts.map((p) => ({
    params: { slug: p.slug }, // Astro crea el slug automáticamente
    props: { 
      // Pasamos la data con la misma estructura que tenía tu backend
      product: {
        ...p.data,
        slug: p.slug
      } 
    }, 
  }));
}

// 2. Recibir producto
const { product } = Astro.props;

if (!product) {
  return Astro.redirect('/upstore');
}

// 3. LOGICA EXACTA DE COLORES Y ESTILOS DEL CATALOGO
const categoryConfig = {
  'MINI_UPS': { name: 'Mini UPS', icon: '🔌' },
  'MONOFASICO': { name: 'Monofásico', icon: '⚡' },
  'BIFASICO': { name: 'Bifásico', icon: '⚡⚡' },
  'TRIFASICO': { name: 'Trifásico', icon: '⚡⚡⚡' }
};

const getCategoryDisplay = (category) => {
  const config = categoryConfig[category] || { name: category, icon: '' };
  return `<span class="mr-1">${config.icon}</span>${config.name}`;
};

// Mismos btnClass y btnText de tu catálogo original
const getStatusConfig = (status) => {
  switch (status) {
    case 'STOCK':
      return { bgClass: 'from-green-600 to-green-700', icon: '<svg class="w-3 h-3 inline mr-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>', text: 'DISPONIBLE', btnClass: 'bg-green-500 hover:bg-green-600', btnText: 'Comprar Ahora' };
    case 'PREVENTA':
      return { bgClass: 'from-blue-600 to-blue-700', icon: '<span class="mr-1">⏰</span>', text: 'PREVENTA', btnClass: 'bg-blue-500 hover:bg-blue-600', btnText: 'Reservar ahora' };
    case 'POR_LLEGAR':
      return { bgClass: 'from-purple-500 to-purple-600', icon: '<span class="mr-1">🚢</span>', text: 'POR LLEGAR', btnClass: 'bg-purple-500 hover:bg-purple-600', btnText: 'Reservar ahora' };
    case 'BAJO_PEDIDO':
      return { bgClass: 'from-gray-700 to-gray-800', icon: '<span class="mr-1">📋</span>', text: 'BAJO PEDIDO', btnClass: 'bg-gray-700 hover:bg-gray-800', btnText: 'Pedir ahora' };
    default:
      return { bgClass: 'from-gray-500 to-gray-600', icon: '', text: status, btnClass: 'bg-gray-500 hover:bg-gray-600', btnText: 'Consultar' };
  }
};

const statusInfo = getStatusConfig(product.status);
const canonicalUrl = `${import.meta.env.PUBLIC_SITE_URL || 'https://upstore.com.ec'}/producto/${product.slug}`;
---

<Layout title={`${product.name} | UPStore Ecuador`}>
  <SEO
    pageType="product"
    title={`${product.name} | UPStore Ecuador`}
    description={product.description.substring(0, 150) + '...'}
    canonical={canonicalUrl}
  />

  <GlobalNavbar />
  
  <main class="pt-24 pb-16 min-h-screen bg-gray-50 dark:bg-gray-900 transition-colors duration-300">
    <div class="container mx-auto px-4 max-w-6xl">
      
      <a href="/" class="inline-flex items-center text-blue-600 hover:text-blue-800 font-medium mb-6 transition-colors bg-white px-4 py-2 rounded-full shadow-sm border border-gray-100 hover:shadow">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Volver al Catálogo
      </a>

      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-xl border border-gray-100 dark:border-gray-700 overflow-hidden flex flex-col md:flex-row relative">
        
        {/* Columna Izquierda: Imagen */}
        <div class="md:w-1/2 p-0 flex justify-center items-center bg-white relative overflow-hidden rounded-t-2xl md:rounded-l-2xl md:rounded-tr-none min-h-[620px]">
          
          <div class="watermark-overlay"></div>
          
          <img 
            src={product.imageUrl} 
            alt={product.name}
           class="w-full h-auto max-h-[860px] object-contain hover:scale-105 transition-transform duration-500 relative z-10"
            oncontextmenu="return false;"
            draggable="false"
          />
          
          {/* ETIQUETA DE STATUS (TOP RIGHT) */}
          <div class="absolute top-6 right-6 z-30">
            <span class={`bg-gradient-to-r ${statusInfo.bgClass} text-white px-3 py-1.5 rounded-full text-xs font-bold shadow-lg uppercase tracking-wide flex items-center`}>
               <Fragment set:html={statusInfo.icon} />
               {statusInfo.text}
            </span>
          </div>

          {/* ETIQUETA DE CATEGORÍA (BOTTON LEFT) */}
          <div class="absolute bottom-6 left-6 z-30">
            <div class="bg-black/80 text-white px-3 py-1.5 rounded-md text-xs font-bold backdrop-blur-sm shadow-md uppercase tracking-wider">
              <Fragment set:html={getCategoryDisplay(product.category)} />
            </div>
          </div>
        </div>

        {/* Columna Derecha: Detalles */}
        <div class="md:w-1/2 p-8 lg:p-12 border-t md:border-t-0 md:border-l border-gray-100 dark:border-gray-700 flex flex-col justify-center bg-white dark:bg-gray-800 z-10">
          
          <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mt-2 mb-6 leading-tight">
            {product.name}
          </h1>
          
          <div class="mb-8 bg-blue-50 dark:bg-blue-900/20 p-5 rounded-xl border border-blue-100 dark:border-blue-800/50 inline-block w-full">
            <span class="text-4xl lg:text-5xl font-extrabold text-blue-600 dark:text-blue-400">
              ${Number(product.price).toFixed(2)}
            </span>
            <span class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase ml-2 block sm:inline mt-1 sm:mt-0">IVA Ya Incluido</span>
          </div>

          <div class="prose dark:prose-invert prose-blue max-w-none text-gray-600 dark:text-gray-300 whitespace-pre-line mb-8 text-base lg:text-lg leading-relaxed">
            {product.description}
          </div>

          {/* Enlace Oficial a Especificaciones */}
          {product.productLink && (
            <div class="mb-10 p-5 bg-gray-50 dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-blue-300 transition-colors">
              <a 
                href={product.productLink} 
                target="_blank" 
                rel="noopener noreferrer"
                class="flex items-center text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-bold group text-lg"
              >
                <svg class="w-6 h-6 mr-3 text-gray-400 group-hover:text-blue-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                Ver Ficha Técnica Oficial del Fabricante
                <svg class="w-5 h-5 ml-auto transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
              </a>
            </div>
          )}

          {/* BOTÓN DE CONTACTO (Sincronizado con el estado del producto) */}
          <button 
            class={`w-full ${statusInfo.btnClass} text-white text-xl font-bold py-4 px-8 rounded-xl transition duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 flex items-center justify-center`}
            onclick={`contactProduct('${encodeURIComponent(product.name)}', '${product.price}', '${product.status}')`}
          >
            <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
            </svg>
            {statusInfo.btnText}
          </button>
          
          <p class="text-center text-sm text-gray-500 mt-4 font-medium">Le responderemos a la brevedad posible.</p>

        </div>
      </div>
    </div>
  </main>
  
  <GlobalFooter />
</Layout>

<style>
  .watermark-overlay {
    position: absolute; inset: 0%; z-index: 20; pointer-events: none;
    background-image: url('/images/upstore-logo.svg');
    background-repeat: no-repeat; background-position: 6px 12px;
    background-size: 240px; opacity: 0.15;
  }
  .dark .watermark-overlay { filter: invert(1); opacity: 0.15; }
</style>

<script>
  const WHATSAPP_NUMBER = '593987799459';
  
  window.contactProduct = function(productNameEnc, price, status) {
    const productName = decodeURIComponent(productNameEnc);
    let actionWord = "comprar";
    if (status === 'BAJO_PEDIDO') actionWord = "cotizar";
    if (status === 'PREVENTA' || status === 'POR_LLEGAR') actionWord = "reservar";
    
    const message = `¡Hola! Me interesa ${actionWord} este UPS: ${productName} (Precio ref: $${price}). ¿Podrían ayudarme con el proceso?`;
    const whatsappUrl = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`;
    window.open(whatsappUrl, '_blank');
  };
</script>