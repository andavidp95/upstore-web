---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO/SEO.astro';
import GlobalNavbar from '../components/GlobalNavbar.astro';
import GlobalFooter from '../components/GlobalFooter.astro';
import { getCollection } from 'astro:content';

const allServicios = await getCollection('servicios');
const servicios = allServicios
  .map(item => ({
    name: item.data.name,
    shortDescription: item.data.shortDescription,
    imageUrl: item.data.imageUrl,
    order: item.data.order ?? 99,
    slug: item.slug,
    body: item.body
  }))
  .sort((a, b) => a.order - b.order);

const defaultServicios = [
  {
    name: 'Mantenimiento Preventivo',
    shortDescription: 'Revisión periódica de sistemas UPS para garantizar óptimo rendimiento. Incluye revisión de baterías, calibración, limpieza de componentes y prueba de carga.',
    iconPath: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z'
  },
  {
    name: 'Reparación de UPS',
    shortDescription: 'Diagnóstico y reparación de sistemas UPS con componentes originales. Atención remota o presencial según la ubicación del equipo.',
    iconPath: 'M11.42 15.17l-5.384 5.384a2.025 2.025 0 01-2.864-2.864l5.384-5.384m2.864 2.864L18 7.5l-4.5-4.5-6.364 6.364m5.58-1.758l3.03-3.03a2.025 2.025 0 012.864 2.864l-3.03 3.03'
  },
  {
    name: 'Diseño de Tableros de Bypass y Distribución',
    shortDescription: 'Ingeniería eléctrica para diseño de tableros de bypass, distribución de carga y acometidas industriales para centros de datos y empresas.',
    iconPath: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z'
  },
  {
    name: 'Acometidas para UPS',
    shortDescription: 'Instalación certificada de acometidas eléctricas dedicadas para sistemas UPS monofásicos y trifásicos. Evaluación de capacidad, cableado y puesta en marcha.',
    iconPath: 'M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-2.25 1.313m-13.5 0L3 16.5v-2.25'
  },
  {
    name: 'Alquiler de UPS',
    shortDescription: 'Servicio de alquiler temporal de equipos UPS para eventos, obras, contingencias o necesidades temporales de respaldo energético.',
    iconPath: 'M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5'
  },
  {
    name: 'Sistemas de Puesta a Tierra',
    shortDescription: 'Diseño e instalación de sistemas de puesta a tierra para UPS, cuartos de telecomunicaciones y equipos electráticos críticos.',
    iconPath: 'M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418'
  },
  {
    name: 'Cuartos de Telecomunicaciones',
    shortDescription: 'Diseño y construcción de cuartos de equipos, salas de telecomunicaciones y data rooms con climatización, piso elevado y distribución eléctrica.',
    iconPath: 'M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z'
  },
  {
    name: 'Instalación Profesional',
    shortDescription: 'Instalación certificada de sistemas UPS monofásicos y trifásicos. Incluye evaluación del entorno, cableado y puesta en marcha.',
    iconPath: 'M11.42 15.17l-5.384 5.384a2.025 2.025 0 01-2.864-2.864l5.384-5.384m2.864 2.864L18 7.5l-4.5-4.5-6.364 6.364m5.58-1.758l3.03-3.03a2.025 2.025 0 012.864 2.864l-3.03 3.03'
  }
];

const showDefault = servicios.length === 0;
const displayItems = showDefault ? defaultServicios : servicios;

const seoTitle = "Servicios Especializados UPS – Mantenimiento, Instalación y Reparación | UPStore Ecuador";
const seoDescription = "Servicios especializados de instalación, mantenimiento, reparación, alquiler de UPS, diseño de tableros, puesta a tierra y cuartos de telecomunicaciones en Ecuador.";
const canonicalUrl = `${import.meta.env.PUBLIC_SITE_URL || 'https://upstore.com.ec'}/servicios`;
---

<Layout title={seoTitle}>
  <SEO pageType="home" title={seoTitle} description={seoDescription} canonical={canonicalUrl} />
  <GlobalNavbar />

  <main class="pt-20 pb-16 min-h-screen bg-[#f8f9fb] dark:bg-[#0f1117] transition-colors duration-500">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-12">
        <p class="text-[11px] font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-2">Servicios</p>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-3 tracking-tight">Servicios Especializados</h1>
        <p class="text-gray-500 dark:text-gray-400 max-w-xl mx-auto">Soluciones técnicas completas para sistemas de respaldo energético por equipos certificados</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {displayItems.map((servicio) => (
          <div class="bg-white dark:bg-[#181b25] border border-gray-100 dark:border-white/5 rounded-xl p-6 hover:border-gray-200 dark:hover:border-white/10 hover:shadow-[0_2px_20px_-4px_rgba(0,0,0,0.06)] dark:hover:shadow-[0_2px_20px_-4px_rgba(0,0,0,0.4)] transition-all duration-300 group">
            <div class="w-10 h-10 bg-gray-50 dark:bg-white/5 rounded-lg flex items-center justify-center mb-4 group-hover:bg-blue-50 dark:group-hover:bg-blue-500/10 transition-colors">
              <svg class="w-5 h-5 text-gray-400 dark:text-gray-500 group-hover:text-blue-500 dark:group-hover:text-blue-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={(servicio as any).iconPath || 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z'} />
              </svg>
            </div>
            <h2 class="text-base font-semibold text-gray-900 dark:text-white mb-2">{servicio.name}</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4 leading-relaxed">{servicio.shortDescription}</p>
            <a href="https://wa.me/593987799459?text=Hola,%20me%20interesa%20un%20servicio%20especializado%20UPS" target="_blank" class="inline-flex items-center text-xs font-medium text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors">
              Consultar por WhatsApp
              <svg class="w-3.5 h-3.5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </main>
  <GlobalFooter />
</Layout>
