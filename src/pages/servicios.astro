---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO/SEO.astro';
import GlobalNavbar from '../components/GlobalNavbar.astro';
import GlobalFooter from '../components/GlobalFooter.astro';
import { getCollection } from 'astro:content';

const allServicios = await getCollection('servicios');
const servicios = allServicios.map(item => ({
  name: item.data.name,
  shortDescription: item.data.shortDescription,
  imageUrl: item.data.imageUrl,
  slug: item.slug,
  body: item.body
}));

const seoTitle = "Servicios de Mantenimiento UPS | UPStore Ecuador";
const seoDescription = "Servicios profesionales de instalación, mantenimiento preventivo y correctivo de sistemas UPS en Ecuador.";
const canonicalUrl = `${import.meta.env.PUBLIC_SITE_URL || 'https://upstore.com.ec'}/servicios`;
---

<Layout title={seoTitle}>
  <SEO pageType="home" title={seoTitle} description={seoDescription} canonical={canonicalUrl} />
  <GlobalNavbar />

  <main class="pt-24 pb-16 min-h-screen bg-gray-100">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-gray-900 mb-3">Servicios</h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">Instalación, mantenimiento preventivo y correctivo de sistemas UPS por técnicos certificados</p>
      </div>

      {servicios.length === 0 ? (
        <div class="max-w-4xl mx-auto space-y-6">
          <div class="bg-white border border-gray-200 rounded-xl p-8">
            <div class="flex items-start gap-4">
              <div class="w-14 h-14 bg-purple-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-7 h-7 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <h2 class="text-xl font-bold text-gray-900 mb-1">Mantenimiento Preventivo</h2>
                <p class="text-gray-600 mb-3">Revisión periódica de sistemas UPS para garantizar óptimo rendimiento. Incluye revisión de baterías, calibración, limpieza de componentes y prueba de carga.</p>
                <span class="inline-flex items-center text-purple-600 font-semibold text-sm">Disponible</span>
              </div>
            </div>
          </div>

          <div class="bg-white border border-gray-200 rounded-xl p-8">
            <div class="flex items-start gap-4">
              <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/></svg>
              </div>
              <div>
                <h2 class="text-xl font-bold text-gray-900 mb-1">Instalación Profesional</h2>
                <p class="text-gray-600 mb-3">Instalación certificada de sistemas UPS monofásicos y trifásicos. Incluye evaluación del entorno, cableado y puesta en marcha.</p>
                <span class="inline-flex items-center text-blue-600 font-semibold text-sm">Disponible</span>
              </div>
            </div>
          </div>

          <div class="bg-white border border-gray-200 rounded-xl p-8">
            <div class="flex items-start gap-4">
              <div class="w-14 h-14 bg-green-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              </div>
              <div>
                <h2 class="text-xl font-bold text-gray-900 mb-1">Soporte Técnico</h2>
                <p class="text-gray-600 mb-3">Diagnóstico y reparación de sistemas UPS. Atención remota o presencial según la ubicación del equipo.</p>
                <span class="inline-flex items-center text-green-600 font-semibold text-sm">Disponible</span>
              </div>
            </div>
          </div>
        </div>
      ) : (
        <div class="max-w-4xl mx-auto space-y-6">
          {servicios.map((servicio) => (
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden hover:shadow-lg transition-all duration-300">
              {servicio.imageUrl && (
                <img src={servicio.imageUrl} alt={servicio.name} class="w-full h-48 object-cover" loading="lazy" />
              )}
              <div class="p-8">
                <h2 class="text-2xl font-bold text-gray-900 mb-2">{servicio.name}</h2>
                <p class="text-gray-600 mb-4">{servicio.shortDescription}</p>
                <a href="https://wa.me/593987799459?text=Hola,%20me%20interesa%20un%20servicio%20de%20mantenimiento%20UPS" target="_blank" class="inline-flex items-center bg-purple-600 hover:bg-purple-700 text-white px-6 py-3 rounded-lg font-semibold transition-colors">
                  <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/></svg>
                  Solicitar por WhatsApp
                </a>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </main>
  <GlobalFooter />
</Layout>
