---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO/SEO.astro';
import GlobalNavbar from '../components/GlobalNavbar.astro';
import GlobalFooter from '../components/GlobalFooter.astro';
import { getCollection } from 'astro:content';

const allBaterias = await getCollection('baterias');
const baterias = allBaterias.filter(item => item.data.name !== 'Próximamente').map(item => ({
  name: item.data.name,
  description: item.data.description,
  price: item.data.price,
  imageUrl: item.data.imageUrl,
  status: item.data.status,
  category: item.data.category,
  slug: item.slug
})).sort((a, b) => a.price - b.price);

const categoryConfig = {
  'VRLA': { name: 'VRLA', icon: '🔋' },
  'AGM': { name: 'AGM', icon: '🔋' },
  'BANCO_BATERIAS': { name: 'Banco de Baterías', icon: '⚡' },
  'GABINETE_BATERIA': { name: 'Gabinete', icon: '🗄️' },
  'OTROS': { name: 'Otros', icon: '📦' }
};

const getStatusConfig = (status) => {
  switch (status) {
    case 'STOCK': return { class: 'bg-green-50 dark:bg-green-500/10 text-green-700 dark:text-green-400 border-green-200 dark:border-green-500/20', text: 'En Stock' };
    case 'PREVENTA': return { class: 'bg-blue-50 dark:bg-blue-500/10 text-blue-700 dark:text-blue-400 border-blue-200 dark:border-blue-500/20', text: 'Preventa' };
    case 'POR_LLEGAR': return { class: 'bg-purple-50 dark:bg-purple-500/10 text-purple-700 dark:text-purple-400 border-purple-200 dark:border-purple-500/20', text: 'Por llegar' };
    case 'BAJO_PEDIDO': return { class: 'bg-gray-100 dark:bg-gray-700/50 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-gray-600', text: 'Bajo pedido' };
    default: return { class: 'bg-gray-100 dark:bg-gray-700/50 text-gray-500 dark:text-gray-400 border-gray-200 dark:border-gray-600', text: status };
  }
};

const seoTitle = "Baterías para UPS - VRLA, AGM y Bancos | UPStore Ecuador";
const seoDescription = "Baterías de repuesto para sistemas UPS: VRLA, AGM, bancos de baterías y gabinetes. Envío a todo Ecuador.";
const canonicalUrl = `${import.meta.env.PUBLIC_SITE_URL || 'https://upstore-ec.com'}/baterias`;
---

<Layout title={seoTitle}>
  <SEO pageType="home" title={seoTitle} description={seoDescription} canonical={canonicalUrl} />
  <GlobalNavbar />

  <main class="pt-24 pb-16 min-h-screen bg-[#f8f9fb] dark:bg-[#0f1117] transition-colors duration-500">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <div class="w-16 h-16 bg-gradient-to-br from-amber-500 to-orange-600 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
          <span class="text-3xl">🔋</span>
        </div>
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-3">Baterías para UPS</h1>
        <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">Baterías de repuesto VRLA, AGM, bancos de baterías y gabinetes para sistemas de respaldo energético</p>
      </div>

      {baterias.length === 0 ? (
        <div class="text-center max-w-md mx-auto">
          <div class="bg-white dark:bg-[#181b25] border border-gray-200 dark:border-white/5 rounded-xl p-12">
            <div class="w-20 h-20 bg-amber-100 dark:bg-amber-500/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-4xl">🔋</span>
            </div>
            <h2 class="text-xl font-semibold text-gray-800 dark:text-white mb-2">Catálogo en preparación</h2>
            <p class="text-gray-500 dark:text-gray-400 mb-6">Estamos preparando el catálogo de baterías. Mientras tanto, contáctanos para consultar disponibilidad.</p>
            <a href="https://wa.me/593987799459?text=Hola,%20me%20interesan%20bater%C3%ADas%20para%20UPS" target="_blank" class="inline-flex items-center bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-lg font-semibold transition-colors">
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/></svg>
              Consultar por WhatsApp
            </a>
          </div>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {baterias.map((item) => {
            const statusConfig = getStatusConfig(item.status);
            return (
            <div class="bg-white dark:bg-[#181b25] rounded-xl overflow-hidden hover:shadow-xl transition-all duration-300 border border-gray-100 dark:border-white/5 flex flex-col">
              <div class="relative bg-white dark:bg-[#12141c]">
                <img src={item.imageUrl} alt={item.name} class="w-full h-48 object-contain p-4 mix-blend-multiply dark:mix-blend-normal" loading="lazy" />
                <div class="absolute top-3 left-3">
                  <span class={`text-[11px] font-semibold px-2.5 py-1 rounded-lg border ${statusConfig.class}`}>{statusConfig.text}</span>
                </div>
                <div class="absolute top-3 right-3">
                  <span class="bg-amber-600 dark:bg-amber-500/20 text-white dark:text-amber-400 px-2.5 py-1 rounded-lg text-[11px] font-semibold border border-amber-600 dark:border-amber-500/30">
                    {categoryConfig[item.category]?.icon} {categoryConfig[item.category]?.name || item.category}
                  </span>
                </div>
              </div>
              <div class="p-5 flex flex-col flex-grow">
                <h3 class="font-semibold text-lg text-gray-900 dark:text-white mb-2">{item.name}</h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm mb-4 flex-grow">{item.description}</p>
                <div class="flex justify-between items-center border-t border-gray-100 dark:border-white/5 pt-4">
                  <span class="text-2xl font-bold text-blue-600 dark:text-blue-400">${Number(item.price).toFixed(2)}</span>
                  <a href={`https://wa.me/593987799459?text=${encodeURIComponent(`Hola, me interesa esta batería: ${item.name} ($${item.price})`)}`} target="_blank" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors">
                    Consultar
                  </a>
                </div>
              </div>
            </div>
            );
          })}
        </div>
      )}
    </div>
  </main>
  <GlobalFooter />
</Layout>
