---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO/SEO.astro';
import GlobalNavbar from '../components/GlobalNavbar.astro';
import GlobalFooter from '../components/GlobalFooter.astro';
import BrandsSection from '../components/BrandsSection.astro';
import PromosCarousel from '../components/PromosCarousel.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('equipos');
const allBaterias = await getCollection('baterias');
const realBaterias = allBaterias.filter(b => b.data.price > 0);
const allPromos = await getCollection('promos');

const promoMap = {};
allPromos.filter(p => p.data.active !== false).forEach(p => {
  const key = p.data.productSlug || p.slug;
  promoMap[key] = { price: p.data.price, originalPrice: p.data.originalPrice, discount: p.data.discount, badge: p.data.badge };
});

const products = allProducts.map(p => ({
  name: p.data.name,
  description: p.data.description,
  price: promoMap[p.slug]?.price ?? p.data.price,
  originalPrice: promoMap[p.slug]?.originalPrice ?? null,
  discount: promoMap[p.slug]?.discount ?? null,
  badge: promoMap[p.slug]?.badge ?? null,
  imageUrl: p.data.imageUrl,
  status: p.data.status,
  category: p.data.category,
  brand: p.data.brand,
  capacity: p.data.capacity || 'OTRO',
  voltage: p.data.voltage || '120V',
  formFactor: p.data.formFactor || 'OTRO',
  externalBattery: p.data.externalBattery || false,
  slug: p.slug
})).sort((a, b) => a.price - b.price);

const categoryConfig = {
  'MINI_UPS': { name: 'Mini UPS', icon: '🔌' },
  'MONOFASICO': { name: 'Monofásico ⚡', icon: '' },
  'BIFASICO': { name: 'Bifásico ⚡⚡', icon: '' },
  'TRIFASICO': { name: 'Trifásico ⚡⚡⚡', icon: '' }
};

const brandConfig = {
  'APC': { name: 'APC', logoLight: '/images/brands/apc.svg', logoDark: '/images/brands/apc-dark.svg', color: 'bg-red-100 dark:bg-red-500/10 text-red-700 dark:text-red-400 border-red-200 dark:border-red-500/20' },
  'VERTIV': { name: 'Vertiv', logoLight: '/images/brands/vertiv.svg', logoDark: '/images/brands/vertiv-dark.svg', color: 'bg-blue-100 dark:bg-blue-500/10 text-blue-700 dark:text-blue-400 border-blue-200 dark:border-blue-500/20' },
  'HBIT': { name: 'Hbit', logoLight: '/images/brands/hbit.png', logoDark: '/images/brands/hbit-dark.png', color: 'bg-emerald-100 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 border-emerald-200 dark:border-emerald-500/20' },
  'HKIVI': { name: 'HKIVI', logoLight: '/images/brands/hviki.gif', logoDark: '/images/brands/hviki-dark.gif', color: 'bg-orange-100 dark:bg-orange-500/10 text-orange-700 dark:text-orange-400 border-orange-200 dark:border-orange-500/20' },
  'SHANQIU': { name: 'Shanqiu', logoLight: '/images/brands/shanqiu.png', logoDark: '/images/brands/shanqiu-dark.png', color: 'bg-cyan-100 dark:bg-cyan-500/10 text-cyan-700 dark:text-cyan-400 border-cyan-200 dark:border-cyan-500/20' },
  'OTROS': { name: 'Otros', logoLight: '', logoDark: '', color: 'bg-gray-100 dark:bg-gray-700/50 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-gray-600' }
};

const capacityGroups = [
  { key: 'MINI', label: 'Mini UPS', filter: (c) => c.startsWith('MINI') },
  { key: '1000VA', label: '1000VA', filter: (c) => c === '1000VA' },
  { key: '1500VA', label: '1500VA', filter: (c) => c === '1500VA' },
  { key: '2000VA', label: '2000-2200VA', filter: (c) => ['2000VA','2200VA'].includes(c) },
  { key: '3000VA', label: '3000VA', filter: (c) => c === '3000VA' },
  { key: '6000VA', label: '6000VA', filter: (c) => c === '6000VA' },
  { key: '10KVA', label: '10KVA', filter: (c) => ['10000VA','10KVA'].includes(c) },
  { key: '12KVA', label: '12KVA', filter: (c) => c === '12KVA' },
  { key: '15KVA', label: '15KVA', filter: (c) => ['15000VA','15KVA'].includes(c) },
  { key: '20K+', label: '20KVA+', filter: (c) => ['20000VA','20KVA','30KVA','30000VA','40KVA','50KVA','60KVA','80KVA','100KVA'].includes(c) },
];

const formFactorConfig = {
  'MINI': { name: 'Mini', icon: '📱' },
  'TOWER': { name: 'Torre', icon: '🖥️' },
  'RACK': { name: 'Rack', icon: '📦' },
  'TOWER_RACK': { name: 'Torre/Rack', icon: '🖥️📦' },
  'OTRO': { name: 'Otro', icon: '⬜' }
};

const getStatusBadge = (status) => {
  switch (status) {
    case 'STOCK': return { class: 'bg-emerald-50 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 border-emerald-200 dark:border-emerald-500/20', text: 'Disponible' };
    case 'PREVENTA': return { class: 'bg-blue-50 dark:bg-blue-500/10 text-blue-700 dark:text-blue-400 border-blue-200 dark:border-blue-500/20', text: 'Preventa' };
    case 'POR_LLEGAR': return { class: 'bg-purple-50 dark:bg-purple-500/10 text-purple-700 dark:text-purple-400 border-purple-200 dark:border-purple-500/20', text: 'Por llegar' };
    case 'BAJO_PEDIDO': return { class: 'bg-gray-100 dark:bg-gray-700/50 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-gray-600', text: 'Bajo pedido' };
    default: return { class: 'bg-gray-100 dark:bg-gray-700/50 text-gray-500 dark:text-gray-400 border-gray-200 dark:border-gray-600', text: status };
  }
};

const seoTitle = "Mini UPS & UPS – Sistemas de Alimentación Ininterrumpida (SAI) | UPStore Ecuador";
const seoDescription = "UPStore Ecuador: Sistemas UPS, baterías y accesorios de respaldo energético. Marcas APC, Vertiv, Hbit, HKIVI. Envío a todo Ecuador.";
const seoKeywords = ["ups ecuador", "sistemas de respaldo energético", "ups online", "protección eléctrica", "mini ups", "baterias ups", "mantenimiento ups", "tienda ups guayaquil", "ups quito", "ups cuenca", "respaldo energético empresas ecuador"];
const canonicalUrl = `${import.meta.env.PUBLIC_SITE_URL || 'https://upstore.com.ec'}`;
---

<Layout title={seoTitle}>
  <SEO pageType="home" title={seoTitle} description={seoDescription} keywords={seoKeywords} canonical={canonicalUrl} />
  <GlobalNavbar />

  <main class="pt-14 min-h-screen bg-[#f8f9fb] dark:bg-[#0f1117] transition-colors duration-500">

<!-- HERO + PROMOS + VALUE PROPS - All in one horizontal section -->
    <section class="relative border-b border-gray-100 dark:border-white/5">
      <div class="absolute inset-0 bg-gradient-to-br from-[#e8ecf4] via-[#f0f2f8] to-[#e4e8f2] dark:from-[#12151e] dark:via-[#0f1117] dark:to-[#151922]"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-gradient-to-bl from-blue-500/5 to-transparent dark:from-blue-400/3 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-gradient-to-tr from-indigo-500/5 to-transparent dark:from-indigo-400/3 rounded-full blur-3xl"></div>

      <div class="container mx-auto px-4 py-8 md:py-12 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 items-stretch">
          <!-- Hero text + Value props - LEFT column -->
          <div class="text-center lg:text-left lg:pr-4">
            <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 dark:text-white leading-[1.15] mb-4 tracking-tight">
              <img src="/images/upstore-logo.svg" alt="UPStore" class="h-8 md:h-10 w-auto mb-2 inline-block" onerror="this.style.display='none'" />
              Su tienda online en Ecuador para sistemas de respaldo de energía
            </h1>
            <p class="text-gray-500 dark:text-gray-400 text-base md:text-lg max-w-lg mx-auto lg:mx-0 leading-relaxed mb-6">
              UPS monofásicos, trifásicos, mini UPS, baterías y accesorios con envío a todo Ecuador.
            </p>
            <!-- Value props inside hero -->
            <div class="grid grid-cols-2 gap-x-4 gap-y-2 mt-2">
              <div class="flex items-center gap-1.5">
                <span class="text-sm">🇪🇨</span>
                <p class="text-[11px] font-medium text-gray-600 dark:text-gray-300 leading-tight">Envíos gratis a todo el Ecuador*</p>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="text-sm">⚡</span>
                <p class="text-[11px] font-medium text-gray-600 dark:text-gray-300 leading-tight">Entrega de mini UPS en hasta 72 horas*</p>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="text-sm">💳</span>
                <p class="text-[11px] font-medium text-gray-600 dark:text-gray-300 leading-tight">Aceptamos múltiples formas de pago</p>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="text-sm">🔋</span>
                <p class="text-[11px] font-medium text-gray-600 dark:text-gray-300 leading-tight">Autonomía a medida</p>
              </div>
            </div>
          </div>
          <!-- Promos carousel inline - RIGHT column, constrained -->
          <div class="w-full lg:pl-4 overflow-hidden">
            <div class="relative">
              <PromosCarousel inline={true} />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CATEGORIES - Minimal nav cards -->
    <section class="py-8 md:py-10">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
          <a href="#equipos" class="group relative flex items-center gap-4 bg-white dark:bg-[#181b25] rounded-xl p-4 border border-gray-100 dark:border-white/5 hover:border-gray-200 dark:hover:border-white/10 transition-all duration-300 hover:shadow-[0_2px_20px_-4px_rgba(0,0,0,0.08)] dark:hover:shadow-[0_2px_20px_-4px_rgba(0,0,0,0.4)]">
            <div class="w-11 h-11 rounded-lg bg-gray-50 dark:bg-white/5 flex items-center justify-center flex-shrink-0 group-hover:bg-blue-50 dark:group-hover:bg-blue-500/10 transition-colors">
              <svg class="w-5 h-5 text-gray-400 dark:text-gray-500 group-hover:text-blue-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <div class="flex-grow min-w-0">
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">Equipos UPS</h3>
              <p class="text-xs text-gray-400 dark:text-gray-500">{allProducts.length} productos</p>
            </div>
            <svg class="w-4 h-4 text-gray-300 dark:text-gray-600 group-hover:text-blue-400 group-hover:translate-x-0.5 transition-all flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href="/baterias" class="group relative flex items-center gap-4 bg-white dark:bg-[#181b25] rounded-xl p-4 border border-gray-100 dark:border-white/5 hover:border-gray-200 dark:hover:border-white/10 transition-all duration-300 hover:shadow-[0_2px_20px_-4px_rgba(0,0,0,0.08)] dark:hover:shadow-[0_2px_20px_-4px_rgba(0,0,0,0.4)]">
            <div class="w-11 h-11 rounded-lg bg-gray-50 dark:bg-white/5 flex items-center justify-center flex-shrink-0 group-hover:bg-amber-50 dark:group-hover:bg-amber-500/10 transition-colors">
              <svg class="w-5 h-5 text-gray-400 dark:text-gray-500 group-hover:text-amber-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 10.5h.375c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125H21M3.75 18h15A2.25 2.25 0 0021 15.75v-6a2.25 2.25 0 00-2.25-2.25h-15A2.25 2.25 0 001.5 9.75v6A2.25 2.25 0 003.75 18z"/></svg>
            </div>
            <div class="flex-grow min-w-0">
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">Baterías</h3>
              <p class="text-xs text-gray-400 dark:text-gray-500">{realBaterias.length} productos</p>
            </div>
            <svg class="w-4 h-4 text-gray-300 dark:text-gray-600 group-hover:text-amber-400 group-hover:translate-x-0.5 transition-all flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href="/accesorios" class="group relative flex items-center gap-4 bg-white dark:bg-[#181b25] rounded-xl p-4 border border-gray-100 dark:border-white/5 hover:border-gray-200 dark:hover:border-white/10 transition-all duration-300 hover:shadow-[0_2px_20px_-4px_rgba(0,0,0,0.08)] dark:hover:shadow-[0_2px_20px_-4px_rgba(0,0,0,0.4)]">
            <div class="w-11 h-11 rounded-lg bg-gray-50 dark:bg-white/5 flex items-center justify-center flex-shrink-0 group-hover:bg-emerald-50 dark:group-hover:bg-emerald-500/10 transition-colors">
              <svg class="w-5 h-5 text-gray-400 dark:text-gray-500 group-hover:text-emerald-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25z"/></svg>
            </div>
            <div class="flex-grow min-w-0">
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">Accesorios</h3>
              <p class="text-xs text-gray-400 dark:text-gray-500">SNMP, PDUs, racks y más</p>
            </div>
            <svg class="w-4 h-4 text-gray-300 dark:text-gray-600 group-hover:text-emerald-400 group-hover:translate-x-0.5 transition-all flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href="/servicios" class="group relative flex items-center gap-4 bg-white dark:bg-[#181b25] rounded-xl p-4 border border-gray-100 dark:border-white/5 hover:border-gray-200 dark:hover:border-white/10 transition-all duration-300 hover:shadow-[0_2px_20px_-4px_rgba(0,0,0,0.08)] dark:hover:shadow-[0_2px_20px_-4px_rgba(0,0,0,0.4)]">
            <div class="w-11 h-11 rounded-lg bg-gray-50 dark:bg-white/5 flex items-center justify-center flex-shrink-0 group-hover:bg-violet-50 dark:group-hover:bg-violet-500/10 transition-colors">
              <svg class="w-5 h-5 text-gray-400 dark:text-gray-500 group-hover:text-violet-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.42 15.17l-5.384 3.18A1.5 1.5 0 014.5 17.08V6.92a1.5 1.5 0 011.536-1.27l5.384 3.18a1.5 1.5 0 010 2.54z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 12c0-2.485-2.099-4.685-5.25-5.25m5.25 5.25c0 2.485-2.099 4.685-5.25 5.25m5.25-5.25v-1.5m0 6.75v-1.5"/></svg>
            </div>
            <div class="flex-grow min-w-0">
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">Servicios Especializados</h3>
              <p class="text-xs text-gray-400 dark:text-gray-500">Mantenimiento, reparación e instalación</p>
            </div>
            <svg class="w-4 h-4 text-gray-300 dark:text-gray-600 group-hover:text-violet-400 group-hover:translate-x-0.5 transition-all flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- PRODUCTS GRID -->
    <section id="equipos" class="pb-16">
      <div class="container mx-auto px-4">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-5 gap-4">
          <h2 class="text-xl md:text-2xl font-bold text-gray-900 dark:text-white tracking-tight">Equipos UPS</h2>
          <div class="flex flex-wrap gap-1.5">
            <button class="filter-brand active px-3 py-1.5 rounded-lg text-xs font-medium transition-all bg-gray-900 dark:bg-white dark:text-gray-900 text-white" data-brand="all">
              Marcas
            </button>
            {Object.entries(brandConfig).filter(([k]) => !['OTROS'].includes(k)).map(([key, config]) => (
              <button class="filter-brand px-3 py-1.5 rounded-lg text-xs font-medium transition-all bg-white dark:bg-white/5 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-white/10 hover:border-gray-300 dark:hover:border-white/20 flex items-center gap-1.5" data-brand={key}>
                {config.logoLight ? <><img src={config.logoLight} alt={config.name} class="h-3.5 w-auto object-contain dark:hidden" onerror="this.style.display='none'" /><img src={config.logoDark} alt={config.name} class="h-3.5 w-auto object-contain hidden dark:block" onerror="this.style.display='none'" /></> : config.name}
              </button>
            ))}
          </div>
        </div>

        <div class="flex flex-wrap gap-1.5 mb-3">
          <button class="filter-btn active px-3 py-1.5 rounded-lg text-xs font-medium transition-all bg-gray-900 dark:bg-white dark:text-gray-900 text-white" data-filter="all">
            Todos ({products.length})
          </button>
          {Object.entries(categoryConfig).map(([key, config]) => (
            <button class="filter-btn px-3 py-1.5 rounded-lg text-xs font-medium transition-all bg-white dark:bg-white/5 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-white/10 hover:border-gray-300 dark:hover:border-white/20" data-filter={key}>
              {config.name}
            </button>
          ))}
        </div>

        <div class="flex flex-wrap gap-1.5 mb-3" id="capacity-filters">
          <span class="text-[11px] text-gray-400 dark:text-gray-500 self-center mr-1">Capacidad:</span>
          <button class="filter-capacity active px-2.5 py-1 rounded-lg text-[11px] font-medium transition-all bg-gray-900 dark:bg-white dark:text-gray-900 text-white" data-capacity="all">
            Todas
          </button>
          {capacityGroups.map((cap) => (
            <button class="filter-capacity px-2.5 py-1 rounded-lg text-[11px] font-medium transition-all bg-white dark:bg-white/5 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-white/10 hover:border-gray-300 dark:hover:border-white/20" data-capacity={cap.key}>
              {cap.label}
            </button>
          ))}
        </div>

        <div class="flex flex-wrap gap-1.5 mb-6" id="formFactor-filters">
          <span class="text-[11px] text-gray-400 dark:text-gray-500 self-center mr-1">Tipo:</span>
          <button class="filter-ff active px-2.5 py-1 rounded-lg text-[11px] font-medium transition-all bg-gray-900 dark:bg-white dark:text-gray-900 text-white" data-ff="all">
            Todos
          </button>
          {Object.entries(formFactorConfig).filter(([k]) => !['OTRO', 'TOWER_RACK'].includes(k)).map(([key, config]) => (
            <button class="filter-ff px-2.5 py-1 rounded-lg text-[11px] font-medium transition-all bg-white dark:bg-white/5 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-white/10 hover:border-gray-300 dark:hover:border-white/20" data-ff={key}>
              {config.name}
            </button>
          ))}
          <button class="filter-ff px-2.5 py-1 rounded-lg text-[11px] font-medium transition-all bg-white dark:bg-white/5 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-white/10 hover:border-gray-300 dark:hover:border-white/20" data-ff="TOWER_RACK">
            Torre/Rack
          </button>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4" id="products-grid">
          {products.map((product) => {
            const statusBadge = getStatusBadge(product.status);
            const brandBadge = brandConfig[product.brand] || brandConfig['OTROS'];
            const safeName = encodeURIComponent(product.name || '');

            return (
            <div
              class={`product-card bg-white dark:bg-[#181b25] rounded-xl border overflow-hidden transition-all duration-300 flex flex-col ${product.badge ? 'border-indigo-200 dark:border-indigo-500/30 hover:border-indigo-400 dark:hover:border-indigo-500/50 shadow-[0_0_12px_-3px_rgba(99,102,241,0.12)]' : 'border-gray-100 dark:border-white/5 hover:border-gray-200 dark:hover:border-white/10 hover:shadow-[0_4px_24px_-6px_rgba(0,0,0,0.07)]'}`}
              data-category={product.category}
              data-brand={product.brand}
              data-capacity={product.capacity}
              data-ff={product.formFactor}
            >
              <a href={`/producto/${product.slug}`} class="block relative bg-gray-50 dark:bg-[#12141c]">
                <img
                  src={product.imageUrl}
                  alt={product.name}
                  class="w-full h-44 md:h-52 object-contain p-3 mix-blend-multiply dark:mix-blend-normal"
                  loading="lazy"
                  onerror="this.style.display='none'"
                />
                <span class="absolute top-2 left-2">
                  {brandBadge.logoLight ? (
                    <>
                      <img src={brandBadge.logoLight} alt={brandBadge.name} class="h-6 md:h-7 w-auto object-contain dark:hidden" onerror="this.style.display='none'" />
                      <img src={brandBadge.logoDark} alt={brandBadge.name} class="h-6 md:h-7 w-auto object-contain hidden dark:block" onerror="this.style.display='none'" />
                    </>
                  ) : null}
                  <span class={brandBadge.logoLight ? "hidden" : "" + " text-[9px] font-bold text-gray-500 dark:text-gray-400"}>{brandBadge.name}</span>
                </span>
                <span class={`absolute top-2 right-2 text-[10px] font-medium px-2 py-0.5 rounded-md border ${statusBadge.class}`}>
                  {statusBadge.text}
                </span>
                {product.badge && (
                  <span class="absolute top-12 right-2 text-[10px] font-bold px-2 py-0.5 rounded-md bg-gradient-to-r from-indigo-500 to-indigo-600 text-white z-10 shadow-sm shadow-indigo-500/30 flex items-center gap-1">
                    <span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse"></span>
                    EN OFERTA
                  </span>
                )}
                {product.formFactor && product.formFactor !== 'OTRO' && product.formFactor !== 'MINI' && (
                  <span class="absolute bottom-2 left-2 text-[10px] font-medium px-2 py-0.5 rounded-md bg-gray-900/70 text-white backdrop-blur-sm">
                    {formFactorConfig[product.formFactor]?.name || product.formFactor}
                  </span>
                )}
{product.externalBattery && (
              <span class="absolute bottom-2 right-2 text-[10px] font-medium px-2 py-0.5 rounded-md bg-emerald-600/80 text-white backdrop-blur-sm flex items-center gap-1">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 10.5h.375c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125H21M3.75 18h15A2.25 2.25 0 0021 15.75v-6a2.25 2.25 0 00-2.25-2.25h-15A2.25 2.25 0 001.5 9.75v6A2.25 2.25 0 003.75 18z"/></svg>
                Autonomía extendible
              </span>
            )}
              </a>
              <div class="p-2.5 md:p-3 flex flex-col flex-grow">
                <a href={`/producto/${product.slug}`}>
                  <h3 class="text-[12px] font-medium text-gray-900 dark:text-white line-clamp-2 mb-1.5 hover:text-blue-600 transition-colors leading-snug">
                    {product.name}
                  </h3>
                </a>
<div class="mt-auto flex items-end justify-between">
                    <div>
                      {product.originalPrice ? (
                        <>
                          <span class="text-sm md:text-base font-bold text-indigo-600">${Number(product.price).toFixed(2)}</span>
                          <span class="text-[10px] text-gray-400 line-through ml-1">${Number(product.originalPrice).toFixed(2)}</span>
                        </>
                      ) : (
                        <span class="text-sm md:text-base font-bold text-gray-900 dark:text-white">${Number(product.price).toFixed(2)}</span>
                      )}
                    </div>
                  <button
                    class="text-[10px] bg-green-600 hover:bg-green-700 text-white px-2.5 py-1 rounded-lg font-medium transition-colors flex items-center gap-1"
                    onclick={`contactProduct('${safeName}', '${product.price}', '${product.status}')`}
                  >
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/></svg>
                    Comprar ahora
                  </button>
                </div>
              </div>
            </div>
            );
          })}
        </div>

        <div id="no-results" class="hidden text-center py-16">
          <p class="text-gray-400 dark:text-gray-500 text-base">No se encontraron productos con estos filtros.</p>
          <button onclick="resetFilters()" class="mt-3 text-blue-600 dark:text-blue-400 hover:text-blue-700 text-sm font-medium">Limpiar filtros</button>
        </div>
      </div>
    </section>
  </main>

  <BrandsSection />

  <!-- CLIENTES SECTION -->
  <section class="py-14 bg-white dark:bg-[#13151d] border-t border-gray-100 dark:border-white/5 transition-colors duration-500">
    <div class="container mx-auto px-4">
      <div class="text-center mb-10">
        <p class="text-[11px] font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-2">Nuestros clientes</p>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white tracking-tight">Empresas que confían en nosotros</h2>
        <div class="w-12 h-0.5 bg-gray-900 dark:bg-white mx-auto mt-4 rounded-full"></div>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
        {[
          { name: 'PICA Plásticos Industriales', logo: '/images/clients/pica.svg' },
          { name: 'GSS Security', logo: '/images/clients/gss.svg' },
        ].map((client) => (
          <div class="group flex flex-col items-center justify-center bg-gray-50 dark:bg-white/[0.03] border border-gray-100 dark:border-white/5 rounded-xl p-6 hover:border-gray-200 dark:hover:border-white/10 hover:shadow-sm transition-all duration-300">
            <img
              src={client.logo}
              alt={client.name}
              class="h-10 md:h-12 object-contain mb-3 opacity-60 dark:opacity-40 group-hover:opacity-100 dark:group-hover:opacity-70 transition-opacity"
              loading="lazy"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='block'"
            />
            <span class="text-sm font-medium text-gray-600 dark:text-gray-400 hidden">{client.name}</span>
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">{client.name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <GlobalFooter />
</Layout>

<style>
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>

<script>
  const WHATSAPP_NUMBER = '593987799459';

  window.contactProduct = function(productNameEnc, price, status) {
    const productName = decodeURIComponent(productNameEnc);
    let actionWord = "comprar";
    if (status === 'BAJO_PEDIDO') actionWord = "cotizar";
    if (status === 'PREVENTA' || status === 'POR_LLEGAR') actionWord = "reservar";
    const message = `¡Hola! Me interesa ${actionWord} este UPS: ${productName} (Precio ref: $${price}). ¿Podrían ayudarme?`;
    window.open(`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`, '_blank');
  };

  function getActiveCapacity(key) {
    const groups = {
      'MINI': (c) => c.startsWith('MINI'),
      '1000VA': (c) => c === '1000VA',
      '1500VA': (c) => c === '1500VA',
      '2000VA': (c) => ['2000VA','2200VA'].includes(c),
      '3000VA': (c) => c === '3000VA',
      '6000VA': (c) => c === '6000VA',
      '10KVA': (c) => ['10000VA','10KVA'].includes(c),
      '12KVA': (c) => c === '12KVA',
      '15KVA': (c) => ['15000VA','15KVA'].includes(c),
      '20K+': (c) => ['20000VA','20KVA','30KVA','30000VA','40KVA','50KVA','60KVA','80KVA','100KVA'].includes(c),
    };
    return groups[key] || (() => true);
  }

  function initializeFilters() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const brandBtns = document.querySelectorAll('.filter-brand');
    const capBtns = document.querySelectorAll('.filter-capacity');
    const ffBtns = document.querySelectorAll('.filter-ff');
    const cards = document.querySelectorAll('.product-card');
    const noResults = document.getElementById('no-results');

    function setActive(btns, activeBtn, activeClasses, inactiveClasses) {
      btns.forEach(b => {
        b.classList.remove('active', ...activeClasses);
        b.classList.add(...inactiveClasses);
      });
      activeBtn.classList.add('active', ...activeClasses);
      activeBtn.classList.remove(...inactiveClasses);
    }

    function applyFilters() {
      const activeFilter = document.querySelector('.filter-btn.active')?.dataset.filter || 'all';
      const activeBrand = document.querySelector('.filter-brand.active')?.dataset.brand || 'all';
      const activeCap = document.querySelector('.filter-capacity.active')?.dataset.capacity || 'all';
      const activeFF = document.querySelector('.filter-ff.active')?.dataset.ff || 'all';
      const capFn = getActiveCapacity(activeCap);
      let count = 0;

      cards.forEach(card => {
        const matchCat = activeFilter === 'all' || card.dataset.category === activeFilter;
        const matchBrand = activeBrand === 'all' || card.dataset.brand === activeBrand;
        const matchCap = activeCap === 'all' || capFn(card.dataset.capacity);
        const matchFF = activeFF === 'all' || card.dataset.ff === activeFF || (activeFF === 'TOWER_RACK' && (card.dataset.ff === 'TOWER' || card.dataset.ff === 'RACK'));
        if (matchCat && matchBrand && matchCap && matchFF) {
          card.style.display = 'flex';
          count++;
        } else {
          card.style.display = 'none';
        }
      });

      noResults.classList.toggle('hidden', count > 0);
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        setActive(filterBtns, this, ['bg-gray-900', 'text-white', 'dark:bg-white', 'dark:text-gray-900'], ['bg-white', 'text-gray-600', 'border', 'border-gray-200', 'dark:bg-white/5', 'dark:text-gray-400', 'dark:border-white/10']);
        applyFilters();
      });
    });

    brandBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        setActive(brandBtns, this, ['bg-gray-900', 'text-white', 'dark:bg-white', 'dark:text-gray-900'], ['bg-white', 'text-gray-600', 'border', 'border-gray-200', 'dark:bg-white/5', 'dark:text-gray-400', 'dark:border-white/10']);
        applyFilters();
      });
    });

    capBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        setActive(capBtns, this, ['bg-gray-900', 'text-white', 'dark:bg-white', 'dark:text-gray-900'], ['bg-white', 'text-gray-600', 'border', 'border-gray-200', 'dark:bg-white/5', 'dark:text-gray-400', 'dark:border-white/10']);
        applyFilters();
      });
    });

    ffBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        setActive(ffBtns, this, ['bg-gray-900', 'text-white', 'dark:bg-white', 'dark:text-gray-900'], ['bg-white', 'text-gray-600', 'border', 'border-gray-200', 'dark:bg-white/5', 'dark:text-gray-400', 'dark:border-white/10']);
        applyFilters();
      });
    });
  }

  window.resetFilters = function() {
    const activeClasses = ['bg-gray-900', 'text-white', 'dark:bg-white', 'dark:text-gray-900'];
    const inactiveClasses = ['bg-white', 'text-gray-600', 'border', 'border-gray-200', 'dark:bg-white/5', 'dark:text-gray-400', 'dark:border-white/10'];

    document.querySelectorAll('.filter-btn').forEach((b, i) => {
      if (i === 0) { b.classList.add('active', ...activeClasses); b.classList.remove(...inactiveClasses); }
      else { b.classList.remove('active', ...activeClasses); b.classList.add(...inactiveClasses); }
    });
    document.querySelectorAll('.filter-brand').forEach((b, i) => {
      if (i === 0) { b.classList.add('active', ...activeClasses); b.classList.remove(...inactiveClasses); }
      else { b.classList.remove('active', ...activeClasses); b.classList.add(...inactiveClasses); }
    });
    document.querySelectorAll('.filter-capacity').forEach((b, i) => {
      if (i === 0) { b.classList.add('active', ...activeClasses); b.classList.remove(...inactiveClasses); }
      else { b.classList.remove('active', ...activeClasses); b.classList.add(...inactiveClasses); }
    });
    document.querySelectorAll('.filter-ff').forEach((b, i) => {
      if (i === 0) { b.classList.add('active', ...activeClasses); b.classList.remove(...inactiveClasses); }
      else { b.classList.remove('active', ...activeClasses); b.classList.add(...inactiveClasses); }
    });
    document.querySelectorAll('.product-card').forEach(c => c.style.display = 'flex');
    document.getElementById('no-results')?.classList.add('hidden');
  };

  document.addEventListener('DOMContentLoaded', initializeFilters);
</script>
