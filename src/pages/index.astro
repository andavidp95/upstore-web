---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO/SEO.astro';
import GlobalNavbar from '../components/GlobalNavbar.astro';
import GlobalFooter from '../components/GlobalFooter.astro';
import BrandsSection from '../components/BrandsSection.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('equipos');
const allBaterias = await getCollection('baterias');
const products = allProducts.map(product => ({
  name: product.data.name,
  description: product.data.description,
  price: product.data.price,
  imageUrl: product.data.imageUrl,
  status: product.data.status,
  category: product.data.category,
  slug: product.slug
}));

let error = null;

const categoryConfig = {
  'MINI_UPS': { name: 'Mini UPS', icon: '🔌' },
  'MONOFASICO': { name: 'Monofásico', icon: '⚡' },
  'BIFASICO': { name: 'Bifásico', icon: '⚡⚡' },
  'TRIFASICO': { name: 'Trifásico', icon: '⚡⚡⚡' }
};

const getCategoryDisplay = (category, includeIcon = false) => {
  const config = categoryConfig[category] || { name: category, icon: '' };
  return includeIcon ? `${config.icon} ${config.name}` : config.name;
};

const getStatusConfig = (status) => {
  switch (status) {
    case 'STOCK':
      return { bgClass: 'from-green-600 to-green-700', icon: '<svg class="w-3 h-3 inline mr-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>', text: 'DISPONIBLE', btnClass: 'bg-green-500 hover:bg-green-600', btnText: 'Comprar Ahora' };
    case 'PREVENTA':
      return { bgClass: 'from-blue-600 to-blue-700', icon: '<span class="mr-1">⏰</span>', text: 'PREVENTA', btnClass: 'bg-blue-500 hover:bg-blue-600', btnText: 'Reservar ahora' };
    case 'POR_LLEGAR':
      return { bgClass: 'from-purple-500 to-purple-600', icon: '<span class="mr-1">🚢</span>', text: 'POR LLEGAR', btnClass: 'bg-purple-500 hover:bg-purple-600', btnText: 'Reservar ahora' };
    case 'BAJO_PEDIDO':
      return { bgClass: 'from-gray-700 to-gray-800', icon: '<span class="mr-1">📋</span>', text: 'BAJO PEDIDO', btnClass: 'bg-gray-700 hover:bg-gray-800', btnText: 'Pedir ahora' };
    default:
      return { bgClass: 'from-gray-500 to-gray-600', icon: '', text: status, btnClass: 'bg-gray-500 hover:bg-gray-600', btnText: 'Consultar' };
  }
};

const seoTitle = "Mini UPS & UPS – Sistemas de Alimentación Ininterrumpida (SAI) | UPStore Ecuador";
const seoDescription = "UPStore Ecuador: Sistemas UPS, accesorios de respaldo energético y servicios de mantenimiento. Amplia gama de soluciones para hogares y empresas en Ecuador.";
const seoKeywords = ["ups ecuador", "sistemas de respaldo energético", "ups online", "protección eléctrica", "mini ups", "baterias ups", "mantenimiento ups"];

const canonicalUrl = `${import.meta.env.PUBLIC_SITE_URL || 'https://upstore.com.ec'}`;
---

<Layout title={seoTitle}>
  <SEO
    pageType="home"
    title={seoTitle}
    description={seoDescription}
    keywords={seoKeywords}
    canonical={canonicalUrl}
  />

  <GlobalNavbar />

  <main class="pt-20 min-h-screen bg-gray-100 transition-colors duration-300">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-20 left-10 w-72 h-72 bg-blue-500/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-purple-500/5 rounded-full blur-3xl"></div>
    </div>

    <div class="container mx-auto px-4 py-8 relative z-10">

      <section class="text-center mb-12">
        <div class="flex justify-center items-center mb-4">
          <div class="w-16 h-16 bg-gradient-to-br from-blue-600 to-purple-600 rounded-xl flex items-center justify-center mr-4 shadow-lg">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900">
            <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">UPStore</span>
          </h1>
        </div>
        <p class="text-xl md:text-2xl font-semibold text-gray-700 mb-4">
          Respaldo energético completo para hogares y empresas en Ecuador
        </p>

        <div class="flex flex-col md:flex-row justify-center items-center gap-3 mb-4 px-2">
          <div class="flex items-center bg-green-50 px-4 py-2 rounded-full border border-green-200 hover:shadow-md transition">
            <span class="text-2xl mr-2">🇪🇨</span>
            <span class="text-green-700 font-semibold text-sm">ENVÍOS GRATIS A TODO EL ECUADOR*</span>
          </div>
          <div class="flex items-center bg-blue-50 px-4 py-2 rounded-full border border-blue-200 hover:shadow-md transition">
            <span class="text-2xl mr-2">⚡</span>
            <span class="text-blue-700 font-semibold text-sm">ENTREGA EN HASTA 72 HORAS*</span>
          </div>
          <div class="flex items-center bg-yellow-50 px-4 py-2 rounded-full border border-yellow-200 hover:shadow-md transition">
            <span class="text-2xl mr-2">💳</span>
            <span class="text-yellow-700 font-semibold text-sm">MÚLTIPLES FORMAS DE PAGO</span>
          </div>
        </div>
      </section>

      <section class="mb-16">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
          <a href="#equipos" class="group relative bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-500 border border-gray-100 hover:border-blue-200">
            <div class="absolute inset-0 bg-gradient-to-br from-blue-50 to-blue-100/50 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="relative p-8 text-center">
              <div class="w-20 h-20 bg-gradient-to-br from-blue-500 to-blue-700 rounded-2xl flex items-center justify-center mx-auto mb-5 shadow-lg shadow-blue-500/25 group-hover:scale-110 transition-transform duration-500">
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">Equipos UPS</h3>
              <p class="text-gray-500 text-sm mb-4">Monofásicos, bifásicos, trifásicos y mini UPS</p>
              <span class="inline-flex items-center text-blue-600 font-semibold text-sm group-hover:text-blue-700">
                {allProducts.length} productos
                <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>

          <a href="/baterias" class="group relative bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-500 border border-gray-100 hover:border-amber-200">
            <div class="absolute inset-0 bg-gradient-to-br from-amber-50 to-orange-100/50 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="relative p-8 text-center">
              <div class="w-20 h-20 bg-gradient-to-br from-amber-500 to-orange-600 rounded-2xl flex items-center justify-center mx-auto mb-5 shadow-lg shadow-amber-500/25 group-hover:scale-110 transition-transform duration-500">
                <span class="text-4xl">🔋</span>
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">Baterías</h3>
              <p class="text-gray-500 text-sm mb-4">VRLA, AGM, bancos de baterías y gabinetes</p>
              <span class="inline-flex items-center text-amber-600 font-semibold text-sm group-hover:text-amber-700">
                {allBaterias.length} productos
                <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>

          <a href="/accesorios" class="group relative bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-500 border border-gray-100 hover:border-emerald-200">
            <div class="absolute inset-0 bg-gradient-to-br from-emerald-50 to-teal-100/50 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="relative p-8 text-center">
              <div class="w-20 h-20 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-2xl flex items-center justify-center mx-auto mb-5 shadow-lg shadow-emerald-500/25 group-hover:scale-110 transition-transform duration-500">
                <span class="text-4xl">🔌</span>
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">Accesorios</h3>
              <p class="text-gray-500 text-sm mb-4">SNMP, PDUs, racks, bypass y repuestos</p>
              <span class="inline-flex items-center text-emerald-600 font-semibold text-sm group-hover:text-emerald-700">
                Ver catálogo
                <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        </div>
      </section>

      <section id="equipos" class="mb-16">
        <div class="text-center mb-8">
          <h2 class="text-3xl font-bold text-gray-900 mb-2">Equipos UPS</h2>
          <p class="text-gray-600">Sistemas de alimentación ininterrumpida para toda necesidad</p>
        </div>

        {error ? (
          <div class="text-center max-w-md mx-auto">
            <div class="bg-red-50 border border-red-200 rounded-xl p-8">
              <h3 class="text-lg font-semibold text-red-800 mb-2">Error al cargar el catálogo</h3>
              <p class="text-red-600 mb-4">{error}</p>
              <button onclick="window.location.reload()" class="mt-4 bg-red-600 hover:bg-red-700 text-white px-6 py-2 rounded-lg font-medium">
                Recargar Catálogo
              </button>
            </div>
          </div>
        ) : products.length === 0 ? (
          <div class="text-center max-w-md mx-auto">
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-8">
              <h3 class="text-lg font-semibold text-gray-800 mb-2">Catálogo en preparación</h3>
              <p class="text-gray-600">Próximamente tendremos disponibles las mejores soluciones.</p>
            </div>
          </div>
        ) : (
          <>
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
              <div class="text-gray-600">
                <span id="product-counter" class="font-semibold text-gray-900">{products.length}</span>
                <span id="product-counter-text"> {products.length === 1 ? 'UPS disponible' : 'UPS disponibles'}</span>
              </div>
              <div class="flex flex-wrap gap-2">
                <button class="filter-btn active px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 bg-blue-600 hover:bg-blue-700 text-white shadow-md" data-filter="all">
                  Todos
                </button>
                {Object.entries(categoryConfig).map(([key, config]) => (
                  <button class="filter-btn px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 bg-gray-200 text-gray-700 hover:bg-emerald-100 hover:text-emerald-700" data-filter={key}>
                    <span class="text-lg mr-2">{config.icon}</span>{config.name}
                  </button>
                ))}
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="products-grid" itemScope itemType="https://schema.org/ItemList">
              {products.map((product, index) => {
                const statusConfig = getStatusConfig(product.status);
                const safeName = encodeURIComponent(product.name || '');

                return (
                <div class="product-card bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300 hover:scale-[1.02] group border border-gray-100 flex flex-col" data-category={product.category} itemScope itemType="https://schema.org/Product" itemProp="itemListElement">
                  <meta itemProp="position" content={(index + 1).toString()} />

                  <a href={`/producto/${product.slug}`} class="relative overflow-hidden flex-shrink-0 bg-white block">
                    <div class="watermark-overlay"></div>
                    <img
                      src={product.imageUrl}
                      alt={product.name}
                      class="w-full h-48 object-cover object-center group-hover:scale-110 transition-transform duration-500 bg-white relative z-10"
                      loading="lazy"
                      onerror="this.src='/images/placeholder-ups.jpg'"
                      itemProp="image"
                      oncontextmenu="return false;"
                      draggable="false"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none z-20"></div>

                    <div class="absolute top-3 right-3 z-30">
                      <span class={`bg-gradient-to-r ${statusConfig.bgClass} text-white px-3 py-1 rounded-full text-xs font-semibold shadow-lg uppercase tracking-wide`}>
                        <Fragment set:html={statusConfig.icon} />
                        {statusConfig.text}
                      </span>
                    </div>

                    <div class="absolute bottom-3 left-3 z-30">
                      <div class="bg-black/70 text-white px-2 py-1 rounded text-xs font-medium backdrop-blur-sm shadow-md">
                        <span class="mr-1">{categoryConfig[product.category]?.icon || ''}</span>
                        {getCategoryDisplay(product.category)}
                      </div>
                    </div>
                  </a>

                  <div class="p-5 flex flex-col flex-grow">
                    <a href={`/producto/${product.slug}`}>
                      <h3 class="font-semibold text-lg mb-3 text-gray-900 line-clamp-2 group-hover:text-blue-600 transition-colors duration-300" itemProp="name">
                        {product.name}
                      </h3>
                    </a>
                    <p class="text-gray-600 text-sm mb-4 line-clamp-2 flex-grow" itemProp="description">
                      {product.description}
                    </p>

                    <meta itemProp="availability" content={product.status === 'STOCK' ? 'InStock' : 'PreOrder'} />

                    <div class="flex justify-between items-center mt-auto border-t border-gray-100 pt-4">
                      <div itemProp="offers" itemScope itemType="https://schema.org/Offer">
                        <span class="text-2xl font-bold text-blue-600">
                          ${Number(product.price).toFixed(2)}
                        </span>
                        <div class="text-[10px] text-gray-500 uppercase tracking-wider font-semibold">IVA Ya Incluido</div>
                        <meta itemProp="price" content={Number(product.price).toFixed(2)} />
                        <meta itemProp="priceCurrency" content="USD" />
                      </div>

                      <button
                        class={`${statusConfig.btnClass} text-white px-4 py-2.5 rounded-lg transition-all duration-200 text-sm font-bold hover:shadow-lg transform hover:-translate-y-0.5 group flex items-center shadow-md`}
                        onclick={`contactProduct('${safeName}', '${product.price}', '${product.status}')`}
                      >
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
                        </svg>
                        {statusConfig.btnText}
                      </button>
                    </div>
                  </div>
                </div>
                );
              })}
            </div>
          </>
        )}
      </section>

      <section class="mb-16 bg-gradient-to-br from-gray-50 to-white rounded-2xl p-8 md:p-12 border border-gray-200">
        <div class="text-center mb-8">
          <h2 class="text-3xl font-bold text-gray-900 mb-2">¿Por qué UPStore?</h2>
          <p class="text-gray-600">Soluciones de respaldo energético respaldadas por marcas líderes mundiales</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center mx-auto mb-3">
              <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-1">Garantía Oficial</h3>
            <p class="text-gray-500 text-sm">Todos nuestros productos incluyen garantía del fabricante</p>
          </div>
          <div class="text-center">
            <div class="w-14 h-14 bg-green-100 rounded-xl flex items-center justify-center mx-auto mb-3">
              <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-1">Envío Nacional</h3>
            <p class="text-gray-500 text-sm">Entrega en todo el Ecuador en hasta 72 horas</p>
          </div>
          <div class="text-center">
            <div class="w-14 h-14 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-3">
              <svg class="w-7 h-7 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-1">Soporte Técnico</h3>
            <p class="text-gray-500 text-sm">Equipo especializado en sistemas de respaldo energético</p>
          </div>
          <div class="text-center">
            <div class="w-14 h-14 bg-yellow-100 rounded-xl flex items-center justify-center mx-auto mb-3">
              <svg class="w-7 h-7 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-1">Múltiples Pagos</h3>
            <p class="text-gray-500 text-sm">Transferencia, tarjeta de crédito, débito y más</p>
          </div>
        </div>
      </section>
    </div>
  </main>
  <BrandsSection themeColor="from-blue-600 to-purple-600" />
  <GlobalFooter />
</Layout>

<style>
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  .watermark-overlay {
    position: absolute; inset: 0%; z-index: 20; pointer-events: none;
    background-image: url('/images/upstore-logo.svg');
    background-repeat: no-repeat; background-position: 4px 7px;
    background-size: 160px; opacity: 0.15;
  }
</style>

<script>
  const WHATSAPP_NUMBER = '593987799459';

  window.contactProduct = function(productNameEnc, price, status) {
    const productName = decodeURIComponent(productNameEnc);
    let actionWord = "comprar";
    if (status === 'BAJO_PEDIDO') actionWord = "cotizar";
    if (status === 'PREVENTA' || status === 'POR_LLEGAR') actionWord = "reservar";

    const message = `¡Hola! Me interesa ${actionWord} este UPS: ${productName} (Precio ref: $${price}). ¿Podrían ayudarme con el proceso?`;
    const whatsappUrl = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`;
    window.open(whatsappUrl, '_blank');
  };

  function initializeFilters() {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const productCards = document.querySelectorAll('.product-card');

    filterButtons.forEach(button => {
      button.addEventListener('click', function() {
        const filter = this.dataset.filter;

        filterButtons.forEach(btn => {
          btn.classList.remove('active', 'bg-blue-600', 'text-white');
          btn.classList.add('bg-gray-200', 'text-gray-700');
        });

        this.classList.add('active', 'bg-blue-600', 'text-white');
        this.classList.remove('bg-gray-200', 'text-gray-700');

        let visibleCount = 0;

        productCards.forEach(card => {
          const shouldShow = filter === 'all' || card.dataset.category === filter;
          if (shouldShow) {
            card.style.display = 'flex';
            card.classList.remove('animate-fadeOut');
            card.classList.add('animate-fadeIn');
            visibleCount++;
          } else {
            card.classList.remove('animate-fadeIn');
            card.classList.add('animate-fadeOut');
            setTimeout(() => card.style.display = 'none', 200);
          }
        });

        const counter = document.getElementById('product-counter');
        const counterText = document.getElementById('product-counter-text');
        if(counter && counterText) {
            counter.textContent = visibleCount.toString();
            counterText.textContent = visibleCount === 1 ? ' UPS disponible' : ' UPS disponibles';
        }
      });
    });
  }

  function addAnimationStyles() {
    const style = document.createElement('style');
    style.textContent = `
      @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
      @keyframes fadeOut { from { opacity: 1; transform: translateY(0); } to { opacity: 0; transform: translateY(-10px); } }
      .animate-fadeIn { animation: fadeIn 0.3s ease-out; }
      .animate-fadeOut { animation: fadeOut 0.2s ease-out; }
    `;
    document.head.appendChild(style);
  }

  document.addEventListener('DOMContentLoaded', function() {
    initializeFilters();
    addAnimationStyles();
  });
</script>
