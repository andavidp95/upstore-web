---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO/SEO.astro';
import GlobalNavbar from '../components/GlobalNavbar.astro';
import GlobalFooter from '../components/GlobalFooter.astro';
import BrandsSection from '../components/BrandsSection.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('equipos');
const allBaterias = await getCollection('baterias');

const products = allProducts.map(p => ({
  name: p.data.name,
  description: p.data.description,
  price: p.data.price,
  imageUrl: p.data.imageUrl,
  status: p.data.status,
  category: p.data.category,
  brand: p.data.brand,
  capacity: p.data.capacity || 'OTRO',
  voltage: p.data.voltage || '120V',
  formFactor: p.data.formFactor || 'OTRO',
  slug: p.slug
}));

const categoryConfig = {
  'MINI_UPS': { name: 'Mini UPS', icon: '🔌' },
  'MONOFASICO': { name: 'Monofásico', icon: '⚡' },
  'BIFASICO': { name: 'Bifásico', icon: '⚡⚡' },
  'TRIFASICO': { name: 'Trifásico', icon: '⚡⚡⚡' }
};

const brandConfig = {
  'APC': { name: 'APC', color: 'bg-red-100 text-red-700 border-red-200' },
  'VERTIV': { name: 'Vertiv', color: 'bg-blue-100 text-blue-700 border-blue-200' },
  'EATON': { name: 'Eaton', color: 'bg-yellow-100 text-yellow-700 border-yellow-200' },
  'VICTRON': { name: 'Victron', color: 'bg-cyan-100 text-cyan-700 border-cyan-200' },
  'OTROS': { name: 'Otros', color: 'bg-gray-100 text-gray-600 border-gray-200' }
};

const capacityGroups = [
  { key: 'MINI', label: 'Mini UPS', filter: (c) => c.startsWith('MINI') },
  { key: '1000VA', label: '1000VA', filter: (c) => c === '1000VA' },
  { key: '1500VA', label: '1500VA', filter: (c) => c === '1500VA' },
  { key: '2000VA', label: '2000-2200VA', filter: (c) => ['2000VA','2200VA'].includes(c) },
  { key: '3000VA', label: '3000VA', filter: (c) => c === '3000VA' },
  { key: '6000VA', label: '6000VA', filter: (c) => c === '6000VA' },
  { key: '10K+', label: '10KVA+', filter: (c) => ['10000VA','15000VA','20000VA','10KVA','20KVA','30KVA'].includes(c) },
];

const formFactorConfig = {
  'TORRE': { name: 'Torre', icon: '🖥️' },
  'RACK': { name: 'Rack', icon: '📦' },
  'AMBOS': { name: 'Rack/Torre', icon: '🔄' },
  'OTRO': { name: 'Otro', icon: '⬜' }
};

const getStatusBadge = (status) => {
  switch (status) {
    case 'STOCK': return { class: 'bg-green-50 text-green-700 border-green-200', text: 'Disponible' };
    case 'PREVENTA': return { class: 'bg-blue-50 text-blue-700 border-blue-200', text: 'Preventa' };
    case 'POR_LLEGAR': return { class: 'bg-purple-50 text-purple-700 border-purple-200', text: 'Por llegar' };
    case 'BAJO_PEDIDO': return { class: 'bg-gray-100 text-gray-600 border-gray-200', text: 'Bajo pedido' };
    default: return { class: 'bg-gray-100 text-gray-500 border-gray-200', text: status };
  }
};

const seoTitle = "Mini UPS & UPS – Sistemas de Alimentación Ininterrumpida (SAI) | UPStore Ecuador";
const seoDescription = "UPStore Ecuador: Sistemas UPS, baterías y accesorios de respaldo energético. Marcas APC, Vertiv, Eaton, Victron Energy. Envío a todo Ecuador.";
const seoKeywords = ["ups ecuador", "sistemas de respaldo energético", "ups online", "protección eléctrica", "mini ups", "baterias ups", "mantenimiento ups"];
const canonicalUrl = `${import.meta.env.PUBLIC_SITE_URL || 'https://upstore.com.ec'}`;
---

<Layout title={seoTitle}>
  <SEO pageType="home" title={seoTitle} description={seoDescription} keywords={seoKeywords} canonical={canonicalUrl} />
  <GlobalNavbar />

  <main class="pt-20 min-h-screen bg-gray-50 dark:bg-gray-900 transition-colors duration-300">
    <div class="container mx-auto px-4 py-8">

      <section class="mb-10">
        <div class="flex flex-col lg:flex-row items-center gap-8 mb-8">
          <div class="flex-1 text-center lg:text-left">
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-gray-900 dark:text-white leading-tight mb-3 transition-colors">
              Respaldo energético para hogares y empresas
            </h1>
            <p class="text-gray-500 dark:text-gray-400 text-base md:text-lg max-w-xl mx-auto lg:mx-0 mb-6 transition-colors">
              UPS monofásicos, trifásicos, mini UPS, baterías y accesorios con envío a todo el país.
            </p>
          </div>
          <div class="hidden lg:block w-px h-48 bg-gray-200 dark:bg-gray-700"></div>
          <div class="flex-shrink-0 grid grid-cols-2 gap-3">
            <div class="bg-green-50 border border-green-100 rounded-xl px-4 py-3 text-center min-w-[140px]">
              <span class="text-2xl block mb-1">🚚</span>
              <span class="text-green-700 font-semibold text-xs leading-tight block">ENVÍOS GRATIS<br/>A TODO EL ECUADOR*</span>
            </div>
            <div class="bg-blue-50 border border-blue-100 rounded-xl px-4 py-3 text-center min-w-[140px]">
              <span class="text-2xl block mb-1">⚡</span>
              <span class="text-blue-700 font-semibold text-xs leading-tight block">ENTREGA EN HASTA<br/>72 HORAS*</span>
            </div>
            <div class="bg-yellow-50 border border-yellow-100 rounded-xl px-4 py-3 text-center min-w-[140px]">
              <span class="text-2xl block mb-1">💳</span>
              <span class="text-yellow-700 font-semibold text-xs leading-tight block">MÚLTIPLES FORMAS<br/>DE PAGO</span>
            </div>
            <div class="bg-purple-50 border border-purple-100 rounded-xl px-4 py-3 text-center min-w-[140px]">
              <span class="text-2xl block mb-1">🔋</span>
              <span class="text-purple-700 font-semibold text-xs leading-tight block">AUTONOMÍA<br/>A MEDIDA</span>
            </div>
          </div>
        </div>
      </section>

      <section class="mb-10">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <a href="#equipos" class="flex items-center gap-4 bg-white dark:bg-gray-800 rounded-xl p-5 border border-gray-200 dark:border-gray-700 hover:border-blue-300 hover:shadow-md transition-all duration-200 group">
            <div class="w-12 h-12 bg-blue-50 dark:bg-blue-900/30 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-blue-100 transition-colors">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <div class="flex-grow">
              <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 transition-colors">Equipos UPS</h3>
              <p class="text-gray-500 dark:text-gray-400 text-sm">{allProducts.length} productos</p>
            </div>
            <svg class="w-5 h-5 text-gray-400 group-hover:text-blue-500 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href="/baterias" class="flex items-center gap-4 bg-white dark:bg-gray-800 rounded-xl p-5 border border-gray-200 dark:border-gray-700 hover:border-amber-300 hover:shadow-md transition-all duration-200 group">
            <div class="w-12 h-12 bg-amber-50 dark:bg-amber-900/30 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-amber-100 transition-colors">
              <span class="text-2xl">🔋</span>
            </div>
            <div class="flex-grow">
              <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-amber-600 transition-colors">Baterías</h3>
              <p class="text-gray-500 dark:text-gray-400 text-sm">{allBaterias.length} productos</p>
            </div>
            <svg class="w-5 h-5 text-gray-400 group-hover:text-amber-500 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href="/accesorios" class="flex items-center gap-4 bg-white dark:bg-gray-800 rounded-xl p-5 border border-gray-200 dark:border-gray-700 hover:border-emerald-300 hover:shadow-md transition-all duration-200 group">
            <div class="w-12 h-12 bg-emerald-50 dark:bg-emerald-900/30 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-emerald-100 transition-colors">
              <span class="text-2xl">🔌</span>
            </div>
            <div class="flex-grow">
              <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-emerald-600 transition-colors">Accesorios</h3>
              <p class="text-gray-500 dark:text-gray-400 text-sm">SNMP, PDUs, racks y más</p>
            </div>
            <svg class="w-5 h-5 text-gray-400 group-hover:text-emerald-500 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </section>

      <section id="equipos" class="mb-12">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white transition-colors">Equipos UPS</h2>
          <div class="flex flex-wrap gap-2">
            <button class="filter-brand active px-3 py-1.5 rounded-lg text-sm font-medium transition-all bg-blue-600 text-white" data-brand="all">
              Marcas
            </button>
            {Object.entries(brandConfig).filter(([k]) => k !== 'OTROS').map(([key, config]) => (
              <button class="filter-brand px-3 py-1.5 rounded-lg text-sm font-medium transition-all bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-300 border border-gray-200 dark:border-gray-600 hover:border-gray-300" data-brand={key}>
                {config.name}
              </button>
            ))}
          </div>
        </div>

        <div class="flex flex-wrap gap-2 mb-4">
          <button class="filter-btn active px-3 py-1.5 rounded-md text-xs font-medium transition-all bg-gray-900 text-white" data-filter="all">
            Todos ({products.length})
          </button>
          {Object.entries(categoryConfig).map(([key, config]) => (
            <button class="filter-btn px-3 py-1.5 rounded-md text-xs font-medium transition-all bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-300 border border-gray-200 dark:border-gray-600 hover:border-gray-300" data-filter={key}>
              {config.name}
            </button>
          ))}
        </div>

        <div class="flex flex-wrap gap-2 mb-4" id="capacity-filters">
          <span class="text-xs text-gray-400 self-center mr-1">Capacidad:</span>
          <button class="filter-capacity active px-2.5 py-1 rounded-md text-xs font-medium transition-all bg-gray-900 text-white" data-capacity="all">
            Todas
          </button>
          {capacityGroups.map((cap) => (
            <button class="filter-capacity px-2.5 py-1 rounded-md text-xs font-medium transition-all bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-300 border border-gray-200 dark:border-gray-600 hover:border-gray-300" data-capacity={cap.key}>
              {cap.label}
            </button>
          ))}
        </div>

        <div class="flex flex-wrap gap-2 mb-6" id="formFactor-filters">
          <span class="text-xs text-gray-400 self-center mr-1">Tipo:</span>
          <button class="filter-ff active px-2.5 py-1 rounded-md text-xs font-medium transition-all bg-gray-900 text-white" data-ff="all">
            Todos
          </button>
          {Object.entries(formFactorConfig).filter(([k]) => k !== 'OTRO').map(([key, config]) => (
            <button class="filter-ff px-2.5 py-1 rounded-md text-xs font-medium transition-all bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-300 border border-gray-200 dark:border-gray-600 hover:border-gray-300" data-ff={key}>
              {config.icon} {config.name}
            </button>
          ))}
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4" id="products-grid">
          {products.map((product) => {
            const statusBadge = getStatusBadge(product.status);
            const brandBadge = brandConfig[product.brand] || brandConfig['OTROS'];
            const safeName = encodeURIComponent(product.name || '');

            return (
            <div
              class="product-card bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden hover:border-gray-300 dark:hover:border-gray-600 hover:shadow-sm transition-all duration-200 flex flex-col"
              data-category={product.category}
              data-brand={product.brand}
              data-capacity={product.capacity}
              data-ff={product.formFactor}
            >
              <a href={`/producto/${product.slug}`} class="block relative bg-gray-50 dark:bg-gray-700/50">
                <img
                  src={product.imageUrl}
                  alt={product.name}
                  class="w-full h-40 object-contain p-3"
                  loading="lazy"
                  onerror="this.style.display='none'"
                />
                <span class={`absolute top-2 left-2 text-[10px] font-medium px-2 py-0.5 rounded border ${brandBadge.class}`}>
                  {brandBadge.name}
                </span>
                <span class={`absolute top-2 right-2 text-[10px] font-medium px-2 py-0.5 rounded border ${statusBadge.class}`}>
                  {statusBadge.text}
                </span>
              </a>
              <div class="p-3 flex flex-col flex-grow">
                <a href={`/producto/${product.slug}`}>
                  <h3 class="text-sm font-medium text-gray-900 dark:text-white line-clamp-2 mb-2 hover:text-blue-600 transition-colors leading-snug">
                    {product.name}
                  </h3>
                </a>
                <div class="mt-auto flex items-end justify-between">
                  <div>
                    <span class="text-lg font-bold text-gray-900 dark:text-white">${Number(product.price).toFixed(0)}</span>
                    <span class="text-xs text-gray-400 ml-0.5">.00</span>
                  </div>
                  <button
                    class="text-xs bg-gray-900 dark:bg-white dark:text-gray-900 hover:bg-gray-800 dark:hover:bg-gray-100 text-white px-3 py-1.5 rounded-md font-medium transition-colors"
                    onclick={`contactProduct('${safeName}', '${product.price}', '${product.status}')`}
                  >
                    Consultar
                  </button>
                </div>
              </div>
            </div>
            );
          })}
        </div>

        <div id="no-results" class="hidden text-center py-12">
          <p class="text-gray-400 text-lg">No se encontraron productos con estos filtros.</p>
          <button onclick="resetFilters()" class="mt-3 text-blue-600 hover:text-blue-700 text-sm font-medium">Limpiar filtros</button>
        </div>
      </section>
    </div>
  </main>
  <BrandsSection />

  <section class="py-12 bg-white dark:bg-gray-900 border-t border-gray-100 dark:border-gray-800 transition-colors">
    <div class="container mx-auto px-4">
      <div class="text-center mb-8">
        <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Medios de pago y envío de confianza</p>
      </div>
      <div class="flex flex-wrap justify-center items-center gap-8 md:gap-14">
        <div class="flex flex-col items-center gap-2 group">
          <div class="w-28 h-14 flex items-center justify-center rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700 px-4 py-2 group-hover:border-gray-200 dark:group-hover:border-gray-600 group-hover:shadow-sm transition-all">
            <img src="/images/trust/paypal.svg" alt="PayPal" class="max-w-full max-h-full object-contain opacity-70 group-hover:opacity-100 transition-opacity" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
            <span class="text-sm font-bold text-blue-600 hidden">PayPal</span>
          </div>
          <span class="text-xs text-gray-500 font-medium">PayPal</span>
        </div>
        <div class="flex flex-col items-center gap-2 group">
          <div class="w-28 h-14 flex items-center justify-center rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700 px-4 py-2 group-hover:border-gray-200 dark:group-hover:border-gray-600 group-hover:shadow-sm transition-all">
            <img src="/images/trust/servientrega.svg" alt="Servientrega" class="max-w-full max-h-full object-contain opacity-70 group-hover:opacity-100 transition-opacity" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
            <span class="text-sm font-bold text-red-600 hidden">Servientrega</span>
          </div>
          <span class="text-xs text-gray-500 font-medium">Envíos Servientrega</span>
        </div>
        <div class="flex flex-col items-center gap-2 group">
          <div class="w-28 h-14 flex items-center justify-center rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700 px-4 py-2 group-hover:border-gray-200 dark:group-hover:border-gray-600 group-hover:shadow-sm transition-all">
            <img src="/images/trust/tarjeta.svg" alt="Tarjeta de crédito" class="max-w-full max-h-full object-contain opacity-70 group-hover:opacity-100 transition-opacity" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
            <span class="text-sm font-bold text-gray-600 hidden">Tarjeta</span>
          </div>
          <span class="text-xs text-gray-500 font-medium">Tarjeta de crédito</span>
        </div>
      </div>
    </div>
  </section>

  <GlobalFooter />
</Layout>

<style>
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>

<script>
  const WHATSAPP_NUMBER = '593987799459';

  window.contactProduct = function(productNameEnc, price, status) {
    const productName = decodeURIComponent(productNameEnc);
    let actionWord = "comprar";
    if (status === 'BAJO_PEDIDO') actionWord = "cotizar";
    if (status === 'PREVENTA' || status === 'POR_LLEGAR') actionWord = "reservar";
    const message = `¡Hola! Me interesa ${actionWord} este UPS: ${productName} (Precio ref: $${price}). ¿Podrían ayudarme?`;
    window.open(`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`, '_blank');
  };

  function getActiveCapacity(key) {
    const groups = {
      'MINI': (c) => c.startsWith('MINI'),
      '1000VA': (c) => c === '1000VA',
      '1500VA': (c) => c === '1500VA',
      '2000VA': (c) => ['2000VA','2200VA'].includes(c),
      '3000VA': (c) => c === '3000VA',
      '6000VA': (c) => c === '6000VA',
      '10K+': (c) => ['10000VA','15000VA','20000VA','10KVA','20KVA','30KVA'].includes(c),
    };
    return groups[key] || (() => true);
  }

  function initializeFilters() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const brandBtns = document.querySelectorAll('.filter-brand');
    const capBtns = document.querySelectorAll('.filter-capacity');
    const ffBtns = document.querySelectorAll('.filter-ff');
    const cards = document.querySelectorAll('.product-card');
    const noResults = document.getElementById('no-results');

    function setActive(btns, activeBtn, activeClasses, inactiveClasses) {
      btns.forEach(b => {
        b.classList.remove('active', ...activeClasses);
        b.classList.add(...inactiveClasses);
      });
      activeBtn.classList.add('active', ...activeClasses);
      activeBtn.classList.remove(...inactiveClasses);
    }

    function applyFilters() {
      const activeFilter = document.querySelector('.filter-btn.active')?.dataset.filter || 'all';
      const activeBrand = document.querySelector('.filter-brand.active')?.dataset.brand || 'all';
      const activeCap = document.querySelector('.filter-capacity.active')?.dataset.capacity || 'all';
      const activeFF = document.querySelector('.filter-ff.active')?.dataset.ff || 'all';
      const capFn = getActiveCapacity(activeCap);
      let count = 0;

      cards.forEach(card => {
        const matchCat = activeFilter === 'all' || card.dataset.category === activeFilter;
        const matchBrand = activeBrand === 'all' || card.dataset.brand === activeBrand;
        const matchCap = activeCap === 'all' || capFn(card.dataset.capacity);
        const matchFF = activeFF === 'all' || card.dataset.ff === activeFF;
        if (matchCat && matchBrand && matchCap && matchFF) {
          card.style.display = 'flex';
          count++;
        } else {
          card.style.display = 'none';
        }
      });

      noResults.classList.toggle('hidden', count > 0);
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        setActive(filterBtns, this, ['bg-gray-900', 'text-white'], ['bg-white', 'text-gray-600', 'border', 'border-gray-200']);
        applyFilters();
      });
    });

    brandBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        setActive(brandBtns, this, ['bg-blue-600', 'text-white'], ['bg-white', 'text-gray-600', 'border', 'border-gray-200']);
        applyFilters();
      });
    });

    capBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        setActive(capBtns, this, ['bg-gray-900', 'text-white'], ['bg-white', 'text-gray-600', 'border', 'border-gray-200']);
        applyFilters();
      });
    });

    ffBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        setActive(ffBtns, this, ['bg-gray-900', 'text-white'], ['bg-white', 'text-gray-600', 'border', 'border-gray-200']);
        applyFilters();
      });
    });
  }

  window.resetFilters = function() {
    document.querySelectorAll('.filter-btn').forEach((b, i) => {
      if (i === 0) { b.classList.add('active', 'bg-gray-900', 'text-white'); b.classList.remove('bg-white', 'text-gray-600', 'border', 'border-gray-200'); }
      else { b.classList.remove('active', 'bg-gray-900', 'text-white'); b.classList.add('bg-white', 'text-gray-600', 'border', 'border-gray-200'); }
    });
    document.querySelectorAll('.filter-brand').forEach((b, i) => {
      if (i === 0) { b.classList.add('active', 'bg-blue-600', 'text-white'); b.classList.remove('bg-white', 'text-gray-600', 'border', 'border-gray-200'); }
      else { b.classList.remove('active', 'bg-blue-600', 'text-white'); b.classList.add('bg-white', 'text-gray-600', 'border', 'border-gray-200'); }
    });
    document.querySelectorAll('.filter-capacity').forEach((b, i) => {
      if (i === 0) { b.classList.add('active', 'bg-gray-900', 'text-white'); b.classList.remove('bg-white', 'text-gray-600', 'border', 'border-gray-200'); }
      else { b.classList.remove('active', 'bg-gray-900', 'text-white'); b.classList.add('bg-white', 'text-gray-600', 'border', 'border-gray-200'); }
    });
    document.querySelectorAll('.filter-ff').forEach((b, i) => {
      if (i === 0) { b.classList.add('active', 'bg-gray-900', 'text-white'); b.classList.remove('bg-white', 'text-gray-600', 'border', 'border-gray-200'); }
      else { b.classList.remove('active', 'bg-gray-900', 'text-white'); b.classList.add('bg-white', 'text-gray-600', 'border', 'border-gray-200'); }
    });
    document.querySelectorAll('.product-card').forEach(c => c.style.display = 'flex');
    document.getElementById('no-results')?.classList.add('hidden');
  };

  document.addEventListener('DOMContentLoaded', initializeFilters);
</script>
