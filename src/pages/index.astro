---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO/SEO.astro';
import GlobalNavbar from '../components/GlobalNavbar.astro';
import GlobalFooter from '../components/GlobalFooter.astro';
import BrandsSection from '../components/BrandsSection.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('equipos');
const allBaterias = await getCollection('baterias');
const allMarcas = await getCollection('marcas');

const products = allProducts.map(p => ({
  name: p.data.name,
  description: p.data.description,
  price: p.data.price,
  imageUrl: p.data.imageUrl,
  status: p.data.status,
  category: p.data.category,
  brand: p.data.brand,
  slug: p.slug
}));

const marcas = allMarcas
  .filter(m => m.data.active)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .map(m => ({ name: m.data.name, logo: m.data.logo }));

const categoryConfig = {
  'MINI_UPS': { name: 'Mini UPS', icon: '🔌' },
  'MONOFASICO': { name: 'Monofásico', icon: '⚡' },
  'BIFASICO': { name: 'Bifásico', icon: '⚡⚡' },
  'TRIFASICO': { name: 'Trifásico', icon: '⚡⚡⚡' }
};

const brandConfig = {
  'APC': { name: 'APC', color: 'bg-red-100 text-red-700 border-red-200' },
  'VERTIV': { name: 'Vertiv', color: 'bg-blue-100 text-blue-700 border-blue-200' },
  'EATON': { name: 'Eaton', color: 'bg-yellow-100 text-yellow-700 border-yellow-200' },
  'VICTRON': { name: 'Victron', color: 'bg-cyan-100 text-cyan-700 border-cyan-200' },
  'OTROS': { name: 'Otros', color: 'bg-gray-100 text-gray-600 border-gray-200' }
};

const getStatusBadge = (status) => {
  switch (status) {
    case 'STOCK': return { class: 'bg-green-50 text-green-700 border-green-200', text: 'Disponible' };
    case 'PREVENTA': return { class: 'bg-blue-50 text-blue-700 border-blue-200', text: 'Preventa' };
    case 'POR_LLEGAR': return { class: 'bg-purple-50 text-purple-700 border-purple-200', text: 'Por llegar' };
    case 'BAJO_PEDIDO': return { class: 'bg-gray-100 text-gray-600 border-gray-200', text: 'Bajo pedido' };
    default: return { class: 'bg-gray-100 text-gray-500 border-gray-200', text: status };
  }
};

const seoTitle = "Mini UPS & UPS – Sistemas de Alimentación Ininterrumpida (SAI) | UPStore Ecuador";
const seoDescription = "UPStore Ecuador: Sistemas UPS, baterías y accesorios de respaldo energético. Marcas APC, Vertiv, Eaton, Victron Energy. Envío a todo Ecuador.";
const seoKeywords = ["ups ecuador", "sistemas de respaldo energético", "ups online", "protección eléctrica", "mini ups", "baterias ups", "mantenimiento ups"];
const canonicalUrl = `${import.meta.env.PUBLIC_SITE_URL || 'https://upstore.com.ec'}`;
---

<Layout title={seoTitle}>
  <SEO pageType="home" title={seoTitle} description={seoDescription} keywords={seoKeywords} canonical={canonicalUrl} />
  <GlobalNavbar />

  <main class="pt-20 min-h-screen bg-gray-50">
    <div class="container mx-auto px-4 py-8">

      <section class="mb-10">
        <div class="flex flex-col lg:flex-row items-center gap-8 mb-8">
          <div class="flex-1 text-center lg:text-left">
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-gray-900 leading-tight mb-3">
              Respaldo energético para hogares y empresas
            </h1>
            <p class="text-gray-500 text-base md:text-lg max-w-xl mx-auto lg:mx-0 mb-6">
              UPS monofásicos, trifásicos, mini UPS, baterías y accesorios con envío a todo el país.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start">
              <a href="#equipos" class="inline-flex items-center justify-center bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-semibold transition-colors shadow-lg shadow-blue-600/20">
                Ver Catálogo
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </a>
              <a href="https://wa.me/593987799459" target="_blank" class="inline-flex items-center justify-center bg-white hover:bg-gray-50 text-gray-700 px-6 py-3 rounded-lg font-semibold transition-colors border border-gray-200">
                <svg class="w-5 h-5 mr-2 text-green-600" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/></svg>
                Cotizar por WhatsApp
              </a>
            </div>
          </div>
          <div class="hidden lg:block w-px h-48 bg-gray-200"></div>
          <div class="flex-shrink-0 grid grid-cols-2 gap-3">
            <div class="bg-green-50 border border-green-100 rounded-xl px-4 py-3 text-center min-w-[140px]">
              <span class="text-2xl block mb-1">🚚</span>
              <span class="text-green-700 font-semibold text-xs leading-tight block">ENVÍOS GRATIS<br/>A TODO EL ECUADOR*</span>
            </div>
            <div class="bg-blue-50 border border-blue-100 rounded-xl px-4 py-3 text-center min-w-[140px]">
              <span class="text-2xl block mb-1">⚡</span>
              <span class="text-blue-700 font-semibold text-xs leading-tight block">ENTREGA EN HASTA<br/>72 HORAS*</span>
            </div>
            <div class="bg-yellow-50 border border-yellow-100 rounded-xl px-4 py-3 text-center min-w-[140px]">
              <span class="text-2xl block mb-1">💳</span>
              <span class="text-yellow-700 font-semibold text-xs leading-tight block">MÚLTIPLES FORMAS<br/>DE PAGO</span>
            </div>
            <div class="bg-purple-50 border border-purple-100 rounded-xl px-4 py-3 text-center min-w-[140px]">
              <span class="text-2xl block mb-1">🔋</span>
              <span class="text-purple-700 font-semibold text-xs leading-tight block">AUTONOMÍA<br/>A MEDIDA</span>
            </div>
          </div>
        </div>
      </section>

      <section class="mb-10">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <a href="#equipos" class="flex items-center gap-4 bg-white rounded-xl p-5 border border-gray-200 hover:border-blue-300 hover:shadow-md transition-all duration-200 group">
            <div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-blue-100 transition-colors">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <div class="flex-grow">
              <h3 class="font-semibold text-gray-900 group-hover:text-blue-600 transition-colors">Equipos UPS</h3>
              <p class="text-gray-500 text-sm">{allProducts.length} productos</p>
            </div>
            <svg class="w-5 h-5 text-gray-400 group-hover:text-blue-500 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href="/baterias" class="flex items-center gap-4 bg-white rounded-xl p-5 border border-gray-200 hover:border-amber-300 hover:shadow-md transition-all duration-200 group">
            <div class="w-12 h-12 bg-amber-50 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-amber-100 transition-colors">
              <span class="text-2xl">🔋</span>
            </div>
            <div class="flex-grow">
              <h3 class="font-semibold text-gray-900 group-hover:text-amber-600 transition-colors">Baterías</h3>
              <p class="text-gray-500 text-sm">{allBaterias.length} productos</p>
            </div>
            <svg class="w-5 h-5 text-gray-400 group-hover:text-amber-500 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href="/accesorios" class="flex items-center gap-4 bg-white rounded-xl p-5 border border-gray-200 hover:border-emerald-300 hover:shadow-md transition-all duration-200 group">
            <div class="w-12 h-12 bg-emerald-50 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-emerald-100 transition-colors">
              <span class="text-2xl">🔌</span>
            </div>
            <div class="flex-grow">
              <h3 class="font-semibold text-gray-900 group-hover:text-emerald-600 transition-colors">Accesorios</h3>
              <p class="text-gray-500 text-sm">SNMP, PDUs, racks y más</p>
            </div>
            <svg class="w-5 h-5 text-gray-400 group-hover:text-emerald-500 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </section>

      <section id="equipos" class="mb-12">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
          <h2 class="text-2xl font-bold text-gray-900">Equipos UPS</h2>
          <div class="flex flex-wrap gap-2">
            <button class="filter-brand active px-3 py-1.5 rounded-lg text-sm font-medium transition-all bg-blue-600 text-white" data-brand="all">
              Todas
            </button>
            {Object.entries(brandConfig).filter(([k]) => k !== 'OTROS').map(([key, config]) => (
              <button class="filter-brand px-3 py-1.5 rounded-lg text-sm font-medium transition-all bg-white text-gray-600 border border-gray-200 hover:border-gray-300" data-brand={key}>
                {config.name}
              </button>
            ))}
          </div>
        </div>

        <div class="flex flex-wrap gap-2 mb-6">
          <button class="filter-btn active px-3 py-1.5 rounded-md text-xs font-medium transition-all bg-gray-900 text-white" data-filter="all">
            Todos ({products.length})
          </button>
          {Object.entries(categoryConfig).map(([key, config]) => (
            <button class="filter-btn px-3 py-1.5 rounded-md text-xs font-medium transition-all bg-white text-gray-600 border border-gray-200 hover:border-gray-300" data-filter={key}>
              {config.name}
            </button>
          ))}
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4" id="products-grid">
          {products.map((product) => {
            const statusBadge = getStatusBadge(product.status);
            const brandBadge = brandConfig[product.brand] || brandConfig['OTROS'];
            const safeName = encodeURIComponent(product.name || '');

            return (
            <div class="product-card bg-white rounded-lg border border-gray-200 overflow-hidden hover:border-gray-300 hover:shadow-sm transition-all duration-200 flex flex-col" data-category={product.category} data-brand={product.brand}>
              <a href={`/producto/${product.slug}`} class="block relative bg-gray-50">
                <img
                  src={product.imageUrl}
                  alt={product.name}
                  class="w-full h-40 object-contain p-3"
                  loading="lazy"
                  onerror="this.style.display='none'"
                />
                <span class={`absolute top-2 left-2 text-[10px] font-medium px-2 py-0.5 rounded border ${brandBadge.class}`}>
                  {brandBadge.name}
                </span>
                <span class={`absolute top-2 right-2 text-[10px] font-medium px-2 py-0.5 rounded border ${statusBadge.class}`}>
                  {statusBadge.text}
                </span>
              </a>
              <div class="p-3 flex flex-col flex-grow">
                <a href={`/producto/${product.slug}`}>
                  <h3 class="text-sm font-medium text-gray-900 line-clamp-2 mb-2 hover:text-blue-600 transition-colors leading-snug">
                    {product.name}
                  </h3>
                </a>
                <div class="mt-auto flex items-end justify-between">
                  <div>
                    <span class="text-lg font-bold text-gray-900">${Number(product.price).toFixed(0)}</span>
                    <span class="text-xs text-gray-400 ml-0.5">.00</span>
                  </div>
                  <button
                    class="text-xs bg-gray-900 hover:bg-gray-800 text-white px-3 py-1.5 rounded-md font-medium transition-colors"
                    onclick={`contactProduct('${safeName}', '${product.price}', '${product.status}')`}
                  >
                    Consultar
                  </button>
                </div>
              </div>
            </div>
            );
          })}
        </div>
      </section>
    </div>
  </main>
  <BrandsSection themeColor="from-blue-600 to-purple-600" />
  <GlobalFooter />
</Layout>

<style>
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>

<script>
  const WHATSAPP_NUMBER = '593987799459';

  window.contactProduct = function(productNameEnc, price, status) {
    const productName = decodeURIComponent(productNameEnc);
    let actionWord = "comprar";
    if (status === 'BAJO_PEDIDO') actionWord = "cotizar";
    if (status === 'PREVENTA' || status === 'POR_LLEGAR') actionWord = "reservar";
    const message = `¡Hola! Me interesa ${actionWord} este UPS: ${productName} (Precio ref: $${price}). ¿Podrían ayudarme?`;
    window.open(`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`, '_blank');
  };

  function initializeFilters() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const brandBtns = document.querySelectorAll('.filter-brand');
    const cards = document.querySelectorAll('.product-card');

    function applyFilters() {
      const activeFilter = document.querySelector('.filter-btn.active')?.dataset.filter || 'all';
      const activeBrand = document.querySelector('.filter-brand.active')?.dataset.brand || 'all';
      let count = 0;

      cards.forEach(card => {
        const matchCat = activeFilter === 'all' || card.dataset.category === activeFilter;
        const matchBrand = activeBrand === 'all' || card.dataset.brand === activeBrand;
        if (matchCat && matchBrand) {
          card.style.display = 'flex';
          count++;
        } else {
          card.style.display = 'none';
        }
      });
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        filterBtns.forEach(b => { b.classList.remove('active', 'bg-gray-900', 'text-white'); b.classList.add('bg-white', 'text-gray-600', 'border', 'border-gray-200'); });
        this.classList.add('active', 'bg-gray-900', 'text-white');
        this.classList.remove('bg-white', 'text-gray-600', 'border', 'border-gray-200');
        applyFilters();
      });
    });

    brandBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        brandBtns.forEach(b => { b.classList.remove('active', 'bg-blue-600', 'text-white'); b.classList.add('bg-white', 'text-gray-600', 'border', 'border-gray-200'); });
        this.classList.add('active', 'bg-blue-600', 'text-white');
        this.classList.remove('bg-white', 'text-gray-600', 'border', 'border-gray-200');
        applyFilters();
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initializeFilters);
</script>
