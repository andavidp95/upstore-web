---
// =============================================================================
// IMPORTS - Componentes y Utilidades
// =============================================================================
import GlobalNavbar from './GlobalNavbar.astro';
import GlobalFooter from '../components/GlobalFooter.astro';
import CTAButton from './ui/FloatingButtons/CTAButton.astro';

// Componentes de Secciones
import HeroContent from '../components/HeroContent.astro';
import HeroVideoCard from '../components/HeroVideoCard.astro';
import ProfessionalServices from './ProfessionalServices.astro';
import BenefitsSection from '../components/BenefitsSection.astro';
import PartnersSection from '../components/PartnersSection.astro';
import ContactForm from '../components/ContactForm.astro';

// Scripts y Datos
import { ThemeManager } from '../scripts/theme.js';
import { 
  getServiceConfig, 
  getServiceBenefits, 
  getServicePartnersWithLogos
} from '../data/ServicesData.js';

// =============================================================================
// TYPES E INTERFACES
// =============================================================================
export interface Props {
  serviceId: string;
}

// =============================================================================
// CONFIGURACIÓN DEL SERVICIO
// =============================================================================
const { serviceId } = Astro.props;

// Obtener configuración principal del servicio
const config = getServiceConfig(serviceId);
const { 
  title, 
  subtitle, 
  heroDescription, 
  description,
  benefitsDescription,
  themeColor, 
  services, 
  heroImage, 
  starService,
  seoTitle,
  seoDescription
} = config;

// Configuraciones adicionales
const benefits = getServiceBenefits(serviceId);

// Extraemos la data enriquecida (con URLs y logos) de la división actual
const rawPartnersData = getServicePartnersWithLogos(serviceId);
const partnersConfig = rawPartnersData[serviceId.toLowerCase()]; 

// =============================================================================
// SCHEMA.ORG DATA
// =============================================================================
const schemaData = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": seoTitle,
  "description": seoDescription,
  "serviceType": "Engineering Consulting",
  "areaServed": {
    "@type": "Place",
    "name": "Ecuador",
    "addressRegion": "EC",
    "addressCountry": "Ecuador"
  },
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "EC",
    "addressRegion": "Guayas"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de Ingeniería Ecuador",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": starService.title,
          "description": starService.marketingMessage,
          "provider": {
            "@type": "Organization",
            "name": title
          }
        }
      },
      ...services.map((service) => ({
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": service.title,
          "description": service.description + " en Ecuador"
        }
      }))
    ]
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "availableLanguage": ["Spanish", "English"],
    "areaServed": "EC"
  },
  "keywords": `${title.toLowerCase()}, ingeniería ecuador, consultoría técnica ecuador, ${starService.title.toLowerCase()} ecuador`
};
---

<!-- =============================================================================
     LAYOUT PRINCIPAL
     ============================================================================= -->
<div class="min-h-screen bg-gray-100 dark:bg-gray-900 overflow-hidden transition-colors duration-300">
  
  <!-- =============================================================================
       NAVEGACIÓN GLOBAL
       ============================================================================= -->
  <GlobalNavbar currentService={serviceId} />

  <!-- =============================================================================
       HERO SECTION
       ============================================================================= -->
  <section class="relative min-h-[100vh] pt-16 flex items-center justify-center overflow-hidden">
    
    <!-- Background con Gradiente del Servicio -->
    <div class={`absolute inset-0 bg-gradient-to-r ${starService.gradient}`}>
      <div class="absolute inset-0 bg-gradient-to-r from-gray-900/70 via-gray-900/30 to-gray-900/70 dark:from-gray-900/80 dark:via-gray-900/40 dark:to-gray-900/80 transition-colors duration-300"></div>
    </div>
    
    <!-- Efectos Decorativos Premium -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-20 left-20 w-32 h-32 bg-white/5 dark:bg-white/3 rounded-full blur-3xl animate-pulse transition-colors duration-300"></div>
      <div class="absolute bottom-32 right-32 w-40 h-40 bg-white/3 dark:bg-white/2 rounded-full blur-2xl animate-bounce transition-colors duration-300" style="animation-duration: 8s;"></div>
      <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-white/2 dark:bg-white/1 rounded-full blur-3xl transition-colors duration-300"></div>
    </div>
    
    <!-- Container Principal -->
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center min-h-[70vh]">
        
        <!-- Hero Content -->
        <HeroContent 
          title={title}
          subtitle={subtitle}
          heroDescription={heroDescription}
          starService={starService}
        />

        <!-- Hero Video Card -->
        <HeroVideoCard 
          starService={starService} 
          themeColor={themeColor} 
        />
        
      </div>
    </div>
  </section>

  <!-- =============================================================================
       BOTÓN CTA FLOTANTE
       ============================================================================= -->
  <CTAButton themeColor={themeColor} />

  <!-- =============================================================================
       SECCIONES DE CONTENIDO
       ============================================================================= -->
  
  <!-- Servicios Profesionales -->
  <ProfessionalServices 
    services={services} 
    themeColor={starService.gradient} 
    description={description}
  />

  <!-- Sección de Beneficios -->
  <BenefitsSection 
    benefits={benefits} 
    themeColor={starService.gradient} 
    serviceTitle={title}
    benefitsDescription={benefitsDescription}
  />

  <!-- Formulario de Contacto -->
  <ContactForm 
    title={title} 
    themeColor={themeColor}
    siteKey="0x4AAAAAABmIObvYsHsPKW2T" 
 
  />

  <!-- Sección de Partners (Condicional) -->
  {partnersConfig && (
    <PartnersSection 
      partnersConfig={partnersConfig} 
      themeColor={starService.gradient} 
    />
  )}

  <!-- =============================================================================
       FOOTER
       ============================================================================= -->
  <GlobalFooter />

  <!-- =============================================================================
       SEO - SCHEMA.ORG
       ============================================================================= -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  
</div>

<!-- =============================================================================
     ESTILOS GLOBALES
     ============================================================================= -->
<style>
  /* =============================================================================
     SCROLL BEHAVIOR
     ============================================================================= */
  html {
    scroll-behavior: smooth;
  }
  
  /* =============================================================================
     SCROLLBAR PERSONALIZADO
     ============================================================================= */
  ::-webkit-scrollbar {
    width: 6px;
  }
  
  ::-webkit-scrollbar-track {
    @apply bg-gray-200 dark:bg-gray-800;
    transition: background-color 0.3s ease;
  }
  
  ::-webkit-scrollbar-thumb {
    background: linear-gradient(180deg, #3b82f6, #8b5cf6);
    border-radius: 3px;
    transition: background 0.3s ease;
  }
  
  ::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(180deg, #2563eb, #7c3aed);
  }
  
  /* =============================================================================
     DARK MODE PARA SCROLLBAR EN FIREFOX
     ============================================================================= */
  @supports (scrollbar-color: auto auto) {
    * {
      scrollbar-width: thin;
      scrollbar-color: #3b82f6 transparent;
    }
    
    @media (prefers-color-scheme: dark) {
      * {
        scrollbar-color: #3b82f6 #1f2937;
      }
    }
  }
  
  /* =============================================================================
     HERO BACKGROUND EFFECTS
     ============================================================================= */
  .bg-gradient-to-br {
    background-attachment: fixed;
  }
  
  /* =============================================================================
     RESPONSIVE OPTIMIZATIONS
     ============================================================================= */
  @media (max-width: 768px) {
    .bg-gradient-to-br {
      background-attachment: scroll;
    }
  }
  
  /* =============================================================================
     PERFORMANCE OPTIMIZATIONS
     ============================================================================= */
  * {
    /* Mejora el rendimiento de las animaciones */
    will-change: auto;
  }
  
  .animate-pulse,
  .animate-bounce {
    /* Optimización para animaciones */
    transform: translateZ(0);
    backface-visibility: hidden;
  }
</style>