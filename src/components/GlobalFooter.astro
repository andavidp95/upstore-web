---
const socialLinks = [
  {
    name: 'Instagram',
    url: 'https://instagram.com/upstore_ec',
    icon: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z'
  },
  {
    name: 'Facebook',
    url: 'https://facebook.com/upstoreec',
    icon: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z'
  }
];

const offerings = [
  { name: 'Equipos UPS', icon: '⚡', iconBg: 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-600', desc: 'Monofásicos, trifásicos y mini UPS', href: '/#equipos' },
  { name: 'Baterías', icon: '🔋', iconBg: 'bg-blue-100 dark:bg-blue-900/30 text-blue-600', desc: 'VRLA, AGM, bancos y gabinetes', href: '/baterias' },
  { name: 'Accesorios para UPS', icon: '🔌', iconBg: 'bg-purple-100 dark:bg-purple-900/30 text-purple-600', desc: 'SNMP, PDUs, racks y bypass', href: '/accesorios' },
  { name: 'Servicios Especializados', icon: '🛠️', iconBg: 'bg-green-100 dark:bg-green-900/30 text-green-600', desc: 'Mantenimiento e instalación', href: '/servicios' }
];

const news = [
  { title: 'Tendencias en sistemas UPS para 2026', badge: 'Tendencias', badgeColor: 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400', iconColor: 'bg-green-500', icon: '⚡' },
  { title: 'Proyecto datacenter empresarial en Quito', badge: 'Proyectos', badgeColor: 'bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-400', iconColor: 'bg-orange-500', icon: '🏢' },
  { title: 'Importancia del UPS en empresas ecuatorianas', badge: 'Artículos', badgeColor: 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400', iconColor: 'bg-blue-500', icon: '📰' }
];

const locations = ['Guayaquil', 'Samborondón', 'Durán', 'Sangolquí', 'Quito', 'Cuenca', 'Ambato', 'Machala', 'Portoviejo', 'Loja', 'Riobamba', 'Ibarra', 'Santa Elena', 'Manta', 'Latacunga', 'Santo Domingo', 'Quevedo', 'Milagro', 'Resto del país'];
---

<footer class="bg-white dark:bg-[#0f1117] border-t border-gray-200 dark:border-white/5 transition-colors duration-500">
  <div class="container mx-auto px-6 lg:px-8 pt-10 pb-8">

    <!-- 4 columns -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-6 mb-10">

      <!-- Column 1: Brand -->
      <div>
        <img 
          src="/images/upstore-logo.svg" 
          alt="UPStore" 
          class="h-8 w-auto mb-3"
          onerror="this.style.display='none'"
        >
        <p class="text-gray-500 dark:text-gray-400 text-xs leading-relaxed mb-4 max-w-[280px]">
          Tienda especializada en sistemas UPS y respaldo energético en Ecuador. Venta de monofásicos, trifásicos, mini UPS, baterías y accesorios con envío a todo el país.
        </p>
        <div class="flex flex-wrap gap-1.5 mb-4">
          <span class="bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-2 py-0.5 rounded-full text-[10px] font-medium">🇪🇨 Empresa Ecuatoriana</span>
          <span class="bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 px-2 py-0.5 rounded-full text-[10px] font-medium">✓ Certificados</span>
          <span class="bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400 px-2 py-0.5 rounded-full text-[10px] font-medium">⚡ Respuesta 24/7</span>
        </div>
        <div class="flex gap-2">
          {socialLinks.map((social) => (
            <a href={social.url} target="_blank" rel="noopener noreferrer" class="text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-white transition-colors p-2 hover:bg-gray-100 dark:hover:bg-white/5 rounded-lg" aria-label={social.name}>
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d={social.icon}/></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Column 2: Ofrecemos -->
      <div>
        <h3 class="text-gray-900 dark:text-white font-bold text-sm mb-1">Ofrecemos</h3>
        <div class="w-8 h-0.5 bg-gradient-to-r from-blue-500 to-indigo-500 rounded-full mb-4"></div>
        <div class="space-y-2">
          {offerings.map((item) => (
            <a href={item.href} class="flex items-center gap-3 p-2.5 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors group">
              <div class={`w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 ${item.iconBg}`}>
                <span class="text-base">{item.icon}</span>
              </div>
              <div>
                <div class="text-xs font-semibold text-gray-800 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">{item.name}</div>
                <div class="text-[10px] text-gray-400 dark:text-gray-500">{item.desc}</div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Column 3: Contacto + Cobertura -->
      <div>
        <h3 class="text-gray-900 dark:text-white font-bold text-sm mb-1">Contacto Directo</h3>
        <div class="w-8 h-0.5 bg-gradient-to-r from-green-500 to-emerald-500 rounded-full mb-4"></div>
        <a href="https://wa.me/593987799459" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl p-3 mb-4 hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors">
          <svg class="w-8 h-8 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M20.52 3.49A11.94 11.94 0 0012 0C5.37 0 0 5.37 0 12c0 2.11.55 4.09 1.51 5.81L0 24l6.36-1.49C8.04 23.41 9.98 24 12 24c6.63 0 12-5.37 12-12 0-3.19-1.24-6.19-3.48-8.51zM12 22c-1.78 0-3.5-.46-4.99-1.26l-.36-.21-3.64.85.77-3.58-.23-.37A9.93 9.93 0 012 12C2 6.48 6.48 2 12 2s10 4.48 10 10-4.48 10-10 10zm5.5-7.5c-.3-.15-1.77-.87-2.04-.97-.28-.1-.48-.15-.68.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.27-.47-2.42-1.49-.89-.8-1.49-1.78-1.67-2.08-.18-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.68-1.63-.93-2.23-.24-.58-.49-.5-.68-.51h-.58c-.2 0-.52.08-.79.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.22 3.08c.15.2 2.11 3.22 5.11 4.52.71.31 1.27.49 1.71.63.72.23 1.37.2 1.88.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.29.17-1.42-.07-.12-.27-.2-.57-.35z"/></svg>
          <div>
            <div class="font-bold text-sm text-green-700 dark:text-green-400">+593 98 779 9459</div>
            <div class="text-[10px] text-green-600/70 dark:text-green-400/60">Chat directo · Respuesta inmediata</div>
          </div>
        </a>
        <div class="space-y-2 text-gray-500 dark:text-gray-400 text-xs mb-5">
          <div class="flex items-center gap-2"><svg class="w-3.5 h-3.5 text-blue-500 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z"/></svg>Ecuador</div>
          <div class="flex items-center gap-2"><svg class="w-3.5 h-3.5 text-blue-500 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg><a href="mailto:ventas@upstore-ec.com" class="hover:text-gray-900 dark:hover:text-white transition-colors">ventas@upstore-ec.com</a></div>
          <div class="flex items-center gap-2"><svg class="w-3.5 h-3.5 text-blue-500 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>Lun - Dom: 8AM - 8PM</div>
        </div>

        <h3 class="text-gray-900 dark:text-white font-bold text-sm mb-1">Cobertura Nacional</h3>
        <div class="w-8 h-0.5 bg-gradient-to-r from-amber-500 to-orange-500 rounded-full mb-2"></div>
        <p class="text-gray-400 dark:text-gray-500 text-[10px] mb-2">Trabajamos en las siguientes ciudades y alrededores:</p>
        <div class="flex flex-wrap gap-1">
          {locations.map((location) => (
            <span class={`${location === 'Resto del país' ? 'bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-medium' : 'bg-gray-100 dark:bg-white/5 text-gray-500 dark:text-gray-400'} px-2 py-0.5 rounded text-[10px] hover:bg-gray-200 dark:hover:bg-white/10 transition-colors cursor-default`}>{location}</span>
          ))}
        </div>
      </div>

      <!-- Column 4: Últimas Noticias -->
      <div>
        <h3 class="text-gray-900 dark:text-white font-bold text-sm mb-1">Últimas Noticias</h3>
        <div class="w-8 h-0.5 bg-gradient-to-r from-orange-500 to-red-500 rounded-full mb-4"></div>
        <div class="space-y-2.5">
          {news.map((item) => (
            <a href="/noticias" class="flex items-start gap-3 p-2.5 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors group">
              <div class={`w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 ${item.iconColor} text-white text-sm`}>
                {item.icon}
              </div>
              <div class="min-w-0">
                <span class={`text-[9px] font-semibold px-1.5 py-0.5 rounded ${item.badgeColor}`}>{item.badge}</span>
                <p class="text-[11px] font-medium text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white transition-colors mt-0.5 leading-snug line-clamp-2">{item.title}</p>
              </div>
            </a>
          ))}
        </div>
        <a href="/noticias" class="inline-block mt-3 text-[11px] text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-medium transition-colors">
          Ver todas las noticias →
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom bar - centered -->
  <div class="border-t border-gray-200 dark:border-white/5 bg-gray-50 dark:bg-[#0a0c12]">
    <div class="container mx-auto px-6 py-5 text-center">
      <p class="text-gray-500 dark:text-gray-400 text-xs mb-1">© 2026 <strong class="text-gray-800 dark:text-white">UPStore</strong> - Todos los derechos reservados</p>
      <p class="text-[10px] text-gray-400 dark:text-gray-500 mb-3">Página desarrollada por <a href="https://www.theora.tech" target="_blank" rel="noopener noreferrer" class="text-blue-500 dark:text-blue-400 hover:text-blue-600 dark:hover:text-blue-300 font-medium transition-colors">THEORA</a></p>
      <div class="flex flex-wrap justify-center items-center gap-3 text-xs">
        <a href="/terminos-y-condiciones" class="text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">📄 Términos y Condiciones</a>
        <span class="text-gray-300 dark:text-gray-600">·</span>
        <button onclick="scrollToTop()" class="text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors cursor-pointer">↑ Ir al Inicio</button>
        <span class="text-gray-300 dark:text-gray-600">·</span>
        <a href="/" class="text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">🏠 Página Principal</a>
      </div>
    </div>
  </div>
</footer>

<script>
function scrollToTop() {
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
window.scrollToTop = scrollToTop;
</script>
