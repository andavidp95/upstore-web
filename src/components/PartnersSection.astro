---
// Ya no necesitamos importar getPartnerLogoPath porque la data enriquecida ya trae la ruta exacta
export interface Props {
  partnersConfig: {
    title: string;
    subtitle: string;
    categories: Array<{
      name: string;
      // Actualizamos la interfaz: ahora brands es un array de objetos
      brands: Array<{
        name: string;
        logoPath: string;
        website: string | null;
        hasLogo: boolean;
        isSVG: boolean;
      }>;
    }>;
  };
  themeColor: string;
}

const { partnersConfig, themeColor } = Astro.props;
---

<section
  id="partners-section"
  class="py-16 px-4 bg-gray-100 dark:bg-gray-900 relative overflow-hidden transition-colors duration-300"
>
  <div class="absolute inset-0 overflow-hidden">
    <div
      class="absolute top-16 right-8 w-28 h-28 rounded-full blur-3xl animate-pulse bg-gray-200/20 dark:bg-white/5"
    ></div>
    <div
      class="absolute bottom-8 left-8 w-36 h-36 rounded-full blur-2xl bg-gray-200/10 dark:bg-white/3"
      style="animation: slowBounce 8s ease-in-out infinite;"
    ></div>
  </div>

  <div class="container mx-auto relative z-10">
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold mb-6 transition-colors duration-300">
        <span class={`bg-gradient-to-r ${themeColor} bg-clip-text text-transparent`}>
          {partnersConfig.title}
        </span>
      </h2>
      <p class="max-w-3xl mx-auto text-sm md:text-base leading-relaxed transition-colors duration-300 text-gray-700 dark:text-gray-300">
        {partnersConfig.subtitle}
      </p>
    </div>

    <div class="relative">
      <div class="partners-swiper-container">
        <div class="swiper-wrapper">
          {partnersConfig.categories.map((category) => (
            <div class="swiper-slide">
              <div class="text-center mb-6">
                <h3 class="text-2xl font-bold mb-2 transition-colors duration-300 text-gray-900 dark:text-white">
                  {category.name}
                </h3>
                <div class={`w-16 h-1 bg-gradient-to-r ${themeColor} mx-auto rounded-full mb-6`}></div>
              </div>

              <div class="flex flex-wrap justify-center gap-6 px-4">
                {category.brands.map((brand) => {
                  // Magia de Astro: Si hay web, usamos <a>, si no, un <div>
                  const ElementTag = brand.website ? 'a' : 'div';
                  const elementProps = brand.website 
                    ? { href: brand.website, target: "_blank", rel: "noopener noreferrer", title: `Visitar ${brand.name}` }
                    : {};

                  return (
                    <ElementTag 
                      {...elementProps}
                      class={`group relative p-2 transition-all duration-500 hover:scale-105 flex flex-col items-center rounded-lg ${brand.website ? 'cursor-pointer hover:shadow-lg' : ''}`}
                    >
                      <div class="flex items-center justify-center h-16 w-36 mb-2 relative">
                        <img
                          src={brand.logoPath}
                          alt={`${brand.name} logo`}
                          class="
                            max-w-full max-h-full object-contain
                            filter brightness-90 dark:brightness-110
                            group-hover:brightness-110 transition-all duration-300
                          "
                          loading="lazy"
                          onError="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                        />
                        <div
                          class="absolute inset-0 flex items-center justify-center rounded-lg"
                          style="display: none; background: transparent;"
                        >
                          <span class="text-2xl font-bold text-gray-500 dark:text-gray-300 group-hover:text-gray-700 dark:group-hover:text-white transition-colors duration-300">
                            {brand.name.charAt(0)}
                          </span>
                        </div>
                      </div>

                      <div class="text-center">
                        <h4 class={`text-sm font-semibold transition-colors duration-300 text-gray-700 dark:text-gray-300 leading-tight ${brand.website ? 'group-hover:text-blue-500 dark:group-hover:text-blue-400' : 'group-hover:text-gray-900 dark:group-hover:text-white'}`}>
                          {brand.name}
                        </h4>
                      </div>
                    </ElementTag>
                  );
                })}
              </div>
            </div>
          ))}
        </div>

        <div class="partners-swiper-button-next"></div>
        <div class="partners-swiper-button-prev"></div>

        <div class="partners-swiper-pagination"></div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  // Inicializar Partners Swiper cuando el DOM esté listo
  document.addEventListener('DOMContentLoaded', function() {
    new Swiper('.partners-swiper-container', {
      direction: 'horizontal',
      loop: true,
      autoplay: {
        delay: 4000,
        disableOnInteraction: false,
      },
      effect: 'slide',
      slidesPerView: 1,
      spaceBetween: 0,
      pagination: {
        el: '.partners-swiper-pagination',
        clickable: true,
        renderBullet: function (index, className) {
          return '<span class="' + className + ' bg-gray-500/30 dark:bg-gray-300/30 hover:bg-gray-500/60 dark:hover:bg-gray-300/60"></span>';
        },
      },
      navigation: {
        nextEl: '.partners-swiper-button-next',
        prevEl: '.partners-swiper-button-prev',
      },
      breakpoints: {
        640: { slidesPerView: 1 },
        768: { slidesPerView: 1 },
        1024: { slidesPerView: 1 }
      }
    });
  });
</script>

<style>
  @keyframes slowBounce {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
  }

  /* Estilos del carousel */
  .partners-swiper-container {
    position: relative;
    padding-bottom: 30px;
  }

  /* Botones de navegación angulares - Estilo unificado con index */
  .partners-swiper-button-next,
  .partners-swiper-button-prev {
    color: rgba(0, 0, 0, 0.95) !important;
    transition: all 0.3s ease;
    width: 27px !important;
    height: 44px !important;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .partners-swiper-button-next:hover,
  .partners-swiper-button-prev:hover {
    color: rgba(0, 0, 0, 0.7) !important;
  }

  html:not(.dark) .partners-swiper-button-next,
  html:not(.dark) .partners-swiper-button-prev {
    color: rgba(255, 255, 255, 0.95) !important;
  }

  html:not(.dark) .partners-swiper-button-next:hover,
  html:not(.dark) .partners-swiper-button-prev:hover {
    color: rgba(255, 255, 255, 0.8) !important;
  }

  .partners-swiper-button-next { right: -40px; }
  .partners-swiper-button-prev { left: -40px; }

  .partners-swiper-button-next:after,
  .partners-swiper-button-prev:after {
    font-family: 'swiper-icons';
    font-size: 14px;
    color: currentColor;
  }

  @media (max-width: 768px) {
    .partners-swiper-button-next,
    .partners-swiper-button-prev {
      display: none;
    }
    .partners-swiper-container { 
      padding-bottom: 20px; 
    }
  }

  .partners-swiper-pagination {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
  }

  .partners-swiper-pagination .swiper-pagination-bullet {
    width: 12px !important;
    height: 12px !important;
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 1 !important;
    background: rgba(255, 255, 255, 0.7) !important;
    border: 2px solid rgba(255, 255, 255, 0.3);
  }

  .partners-swiper-pagination .swiper-pagination-bullet:hover {
    background: rgba(255, 255, 255, 0.9) !important;
    transform: scale(1.2);
  }

  .partners-swiper-pagination .swiper-pagination-bullet-active {
    background: rgba(255, 255, 255, 1) !important;
    border-color: rgba(255, 255, 255, 0.8);
    transform: scale(1.3);
  }

  html:not(.dark) .partners-swiper-pagination .swiper-pagination-bullet {
    background: rgba(0, 0, 0, 0.5) !important;
    border-color: rgba(0, 0, 0, 0.3);
  }

  html:not(.dark) .partners-swiper-pagination .swiper-pagination-bullet:hover {
    background: rgba(0, 0, 0, 0.7) !important;
  }

  html:not(.dark) .partners-swiper-pagination .swiper-pagination-bullet-active {
    background: rgba(0, 0, 0, 0.8) !important;
    border-color: rgba(0, 0, 0, 0.6);
  }

  .swiper-slide-active .text-center {
    animation: fadeInUp 0.8s ease-out;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>