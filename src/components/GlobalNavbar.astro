---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md border-b border-gray-200 transition-all duration-300" id="globalNavbar">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo Principal -->
      <a href="/" class="flex items-center hover:opacity-80 transition-opacity">
        <img 
          src="/images/upstore-logo.svg" 
          alt="UPStore Logo" 
          class="h-10 w-auto"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
        >
        <!-- Fallback si no se encuentra la imagen -->
        <div class="flex items-center space-x-3 text-gray-900" style="display: none;">
          <div class="w-10 h-10 bg-gradient-to-r from-blue-600 to-purple-600 rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-lg">UP</span>
          </div>
          <span class="font-bold text-xl">UPStore</span>
        </div>
      </a>

      <!-- Enlaces Sociales -->
      <div class="flex items-center space-x-2">
        {socialLinks.map((social) => (
          <a 
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-600 hover:text-gray-900 transition-colors duration-300 p-2 hover:bg-gray-100 rounded-lg"
            aria-label={social.name}
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d={social.icon}/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>
</nav>

<script>
  // Efecto de scroll para el navbar
  let lastScrollY = window.scrollY;
  
  window.addEventListener('scroll', () => {
    const navbar = document.getElementById('globalNavbar');
    const currentScrollY = window.scrollY;
    
    if (currentScrollY > lastScrollY && currentScrollY > 80) {
      navbar.style.transform = 'translateY(-100%)';
    } else {
      navbar.style.transform = 'translateY(0)';
    }
    
    lastScrollY = currentScrollY;
  });
</script>
