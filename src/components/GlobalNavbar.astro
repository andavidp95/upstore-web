  { name: 'Equipos UPS', href: '/#equipos', icon: '⚡', desc: 'UPS online, monofásicos, trifásicos y mini UPS de respaldo' },
  { name: 'Baterías', href: '/baterias', icon: '🔋', desc: 'Baterías VRLA, AGM, bancos y gabinetes para UPS' },
  { name: 'Accesorios', href: '/accesorios', icon: '🔌', desc: 'Tarjetas SNMP, PDUs, racks, bypass y cableado' },
  { name: 'Servicios Especializados', href: '/servicios', icon: '🛠️', desc: 'Mantenimiento preventivo, instalación y soporte técnico especializado' },
];

const socialLinks = [
  {
    name: 'Instagram',
    url: 'https://instagram.com/upstore_ec',
