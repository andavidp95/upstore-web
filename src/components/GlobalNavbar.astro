---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-[#0f1117]/80 backdrop-blur-xl border-b border-gray-100 dark:border-white/5 transition-colors duration-500" id="globalNavbar">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-14">
      <a href="/" class="flex items-center hover:opacity-80 transition-opacity">
        <img
          src="/images/upstore-logo.svg"
          alt="UPStore"
          class="h-8 w-auto"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
        >
        <div class="flex items-center text-gray-900 dark:text-white" style="display: none;">
          <span class="font-bold text-lg tracking-tight">UPStore</span>
        </div>
      </a>

      <div class="hidden md:flex items-center gap-0.5">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="group relative px-3 py-2 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-white/5 rounded-lg transition-colors"
          >
            <span class="mr-1.5">{link.icon}</span>{link.name}
            <div class="absolute left-1/2 -translate-x-1/2 top-full mt-1 w-56 bg-gray-900 dark:bg-[#1e2030] text-white text-xs rounded-xl px-3 py-2 opacity-0 pointer-events-none group-hover:opacity-100 transition-all duration-200 shadow-xl border border-gray-800 dark:border-white/10 z-50 translate-y-1 group-hover:translate-y-0">
              {link.desc}
            </div>
          </a>
        ))}
      </div>

      <div class="flex items-center gap-0.5">
        {socialLinks.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-white transition-colors p-2 hover:bg-gray-50 dark:hover:bg-white/5 rounded-lg"
            aria-label={social.name}
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d={social.icon}/>
            </svg>
          </a>
        ))}
        <button
          id="darkModeToggle"
          class="relative w-9 h-9 flex items-center justify-center text-gray-400 dark:text-gray-400 hover:text-gray-700 dark:hover:text-white transition-colors hover:bg-gray-50 dark:hover:bg-white/5 rounded-lg"
          aria-label="Modo oscuro"
          title="Alternar modo oscuro"
        >
          <svg class="w-[18px] h-[18px] sun-icon transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          <svg class="w-[18px] h-[18px] moon-icon hidden transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
        </button>
      </div>
    </div>
  </div>
</nav>

<script>
  let lastScrollY = window.scrollY;
  window.addEventListener('scroll', () => {
    const navbar = document.getElementById('globalNavbar');
    const currentScrollY = window.scrollY;
    if (currentScrollY > lastScrollY && currentScrollY > 80) {
      navbar.style.transform = 'translateY(-100%)';
    } else {
      navbar.style.transform = 'translateY(0)';
    }
    lastScrollY = currentScrollY;
  });

  const toggle = document.getElementById('darkModeToggle');
  const html = document.documentElement;
  const sunIcon = toggle.querySelector('.sun-icon');
  const moonIcon = toggle.querySelector('.moon-icon');

  function updateIcons() {
    if (html.classList.contains('dark')) {
      sunIcon.classList.add('hidden');
      moonIcon.classList.remove('hidden');
    } else {
      moonIcon.classList.add('hidden');
      sunIcon.classList.remove('hidden');
    }
  }

  const saved = localStorage.getItem('theme');
  if (saved === 'dark') { html.classList.add('dark'); }
  updateIcons();

  toggle.addEventListener('click', () => {
    html.classList.toggle('dark');
    localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
    updateIcons();
  });
</script>
