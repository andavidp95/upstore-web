---
export interface Props {
  title: string;
  themeColor: string;
  siteKey?: string; 
}

function getSolidColorsFromGradient(gradient) {
  const colorMap = {
    'from-blue-600 to-purple-600': { bg: '#2563eb', text: '#ffffff' },
    'from-green-600 to-blue-600': { bg: '#16a34a', text: '#ffffff' },
    'from-purple-600 to-pink-600': { bg: '#9333ea', text: '#ffffff' },
  };
  return colorMap[gradient] || { bg: '#2563eb', text: '#ffffff' };
}
import { countries } from '../data/Countries.js';

const { title, themeColor, siteKey = "0x4AAAAAABmIObvYsHsPKW2T" } = Astro.props;
const backgroundColors = getSolidColorsFromGradient(themeColor);

// Lista de iso2 de los países en el select, en el mismo orden "top" que tenías:
// Ecuador, Argentina, Brasil, Chile, Colombia, Costa Rica, EE. UU., México, Perú, Uruguay, Venezuela, Panamá, España
const topIso2 = ['ec','ar','br','cl','co','cr','us','mx','pe','uy','ve','pa','es'];

// Función para obtener emoji de bandera a partir de iso2
function iso2ToFlagEmoji(iso2) {
  // convertir a mayúsculas y luego a regional indicator symbols
  return Array.from(iso2.toUpperCase()).map(ch =>
    String.fromCodePoint(0x1F1E6 + ch.charCodeAt(0) - 65)
  ).join('');
}

// Ordenar: primero los top en el orden dado, luego el resto alfabéticamente por nombre
const sortedCountries = [
  ...topIso2
    .map(code => countries.find(c => c.iso2 === code))
    .filter(Boolean),
  ...countries
    .filter(c => !topIso2.includes(c.iso2))
    .sort((a, b) => a.name.localeCompare(b.name))
];
