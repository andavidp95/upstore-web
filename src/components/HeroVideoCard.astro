---
export interface Props {
  starService: {
    title: string;
    marketingMessage: string;
    videoPlaceholder: string;
    cta: string;
    logo?: string;
  };
  themeColor: string;
  className?: string;
}

const { starService, themeColor, className = "" } = Astro.props;
---

<div class={`animate-fade-in px-4 ${className}`} style="animation-delay: 0.3s;">
  <div class="relative group">
    
    <!-- Video Container -->
    <div class="relative bg-gradient-to-br from-white/20 to-white/5 backdrop-blur-xl rounded-3xl border border-white/30 overflow-hidden shadow-2xl hover:shadow-3xl transition-all duration-700 hover:scale-[1.02]">
      
      <!-- Header del video -->
      <div class="p-4 sm:p-6 border-b border-white/20">
        <div class="flex items-center space-x-3 mb-3">
          {starService.logo && (
            <img
              src={starService.logo}
              alt={`${starService.title} Logo`}
              class="h-6 sm:h-8 w-auto filter drop-shadow-lg flex-shrink-0"
            />
          )}
          <h3 class="text-xl sm:text-2xl md:text-3xl font-black text-white min-w-0 break-words">
            {starService.title}
          </h3>
        </div>
        <p class="text-gray-200 text-base sm:text-lg leading-relaxed font-medium break-words">
          {starService.marketingMessage}
        </p>
      </div>
      
      <!-- Video Space -->
      <div class="relative aspect-video bg-gradient-to-br from-gray-800 to-gray-900 flex items-center justify-center group-hover:from-gray-700 group-hover:to-gray-800 transition-all duration-500">
        
        <!-- Video HTML5 -->
        <video 
          id="hero-video"
          autoplay
          muted
          loop
          playsinline
          controls
          class="w-full h-full object-cover relative z-10"    
        >
          <source src={starService.videoPlaceholder} type="video/mp4">
          Tu navegador no soporta video HTML5.
        </video>
        
        <!-- Botón de sonido personalizado -->
        <button 
          id="sound-toggle"
          class="absolute top-2 sm:top-4 right-2 sm:right-4 z-20 bg-black/60 hover:bg-black/80 text-white p-2 sm:p-3 rounded-full transition-all duration-300 backdrop-blur-sm border border-white/20"
          onclick="toggleSound()"
          title="Activar/Desactivar sonido"
        >
          <svg id="sound-icon" class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24">
            <!-- Icono de sonido desactivado -->
            <path id="muted-icon" d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
            <!-- Icono de sonido activado (oculto inicialmente) -->
            <path id="sound-icon-active" class="hidden" d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
          </svg>
        </button>
        
        <!-- Overlay de interacción -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/10 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none z-5"></div>
      </div>
      
      <!-- Footer del video con CTA -->
      <div class="p-4 sm:p-6 bg-gradient-to-r from-white/10 to-white/5">
        <button 
          onclick="document.getElementById('contact').scrollIntoView({behavior: 'smooth'})"
          class={`w-full bg-gradient-to-r ${themeColor} text-white py-4 px-4 sm:px-6 rounded-xl font-bold text-base sm:text-lg hover:shadow-2xl transition-all duration-300 transform hover:scale-[1.02] shadow-xl flex items-center justify-center space-x-3 group cta-button`}
        >
          <span class="break-words text-center">{starService.cta}</span>
          <svg class="w-4 h-4 sm:w-5 sm:h-5 group-hover:translate-x-1 transition-transform duration-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </button>
      </div>
      
    </div>
    
    <!-- Efectos decorativos alrededor del video -->
    <div class={`absolute -top-4 -right-4 w-6 sm:w-8 h-6 sm:h-8 bg-gradient-to-r ${themeColor} rounded-full animate-pulse z-0 opacity-60`}></div>
    <div class={`absolute -bottom-4 -left-4 w-4 sm:w-6 h-4 sm:h-6 bg-gradient-to-r ${themeColor} rounded-full animate-bounce z-0 opacity-40`} style="animation-delay: 0.5s;"></div>
  </div>
</div>

<script>
  function toggleSound() {
    const video = document.getElementById('hero-video');
    const mutedIcon = document.getElementById('muted-icon');
    const soundIcon = document.getElementById('sound-icon-active');
    
    if (video && mutedIcon && soundIcon) {
      if (video.muted) {
        video.muted = false;
        mutedIcon.classList.add('hidden');
        soundIcon.classList.remove('hidden');
      } else {
        video.muted = true;
        mutedIcon.classList.remove('hidden');
        soundIcon.classList.add('hidden');
      }
    }
  }

  // Evitar conflictos con múltiples instancias
  document.addEventListener('DOMContentLoaded', function() {
    const video = document.getElementById('hero-video');
    const soundButton = document.getElementById('sound-toggle');
    
    if (video && soundButton) {
      video.addEventListener('loadedmetadata', function() {
        console.log('Video cargado correctamente');
      });
      
      soundButton.addEventListener('click', function(e) {
        e.stopPropagation();
        toggleSound();
      });
    }
  });
</script>

<style>
  .aspect-video {
    aspect-ratio: 16 / 9;
  }
  
  .group:hover .aspect-video {
    transform: scale(1.02);
    transition: transform 0.7s ease-out;
  }

  .cta-button:hover {
    filter: brightness(1.1) saturate(1.2);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }
  
  video {
    position: relative;
    z-index: 10;
  }
  
  video::-webkit-media-controls {
    opacity: 0.8;
    z-index: 15;
  }
  
  video::-webkit-media-controls:hover {
    opacity: 1;
  }
  
  #sound-toggle {
    z-index: 20;
    cursor: pointer;
  }
  
  #sound-toggle:hover {
    transform: scale(1.1);
    background: rgba(0, 0, 0, 0.9);
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fade-in {
    animation: fade-in 1s ease-out forwards;
    opacity: 0;
  }
  
  /* Optimización específica para dispositivos problemáticos */
  @media (max-width: 390px) {
    .animate-fade-in {
      animation-duration: 0.8s;
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }
  
  /* iPhone SE y dispositivos muy pequeños */
  @media (max-width: 375px) {
    .animate-fade-in {
      padding-left: 0.75rem;
      padding-right: 0.75rem;
    }
  }
</style>