---
import { getCollection } from 'astro:content';

const allPromos = await getCollection('promos');
const promos = allPromos
  .filter(p => p.data.active !== false)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .map(p => ({
    name: p.data.name,
    description: p.data.description,
    price: p.data.price,
    originalPrice: p.data.originalPrice,
    imageUrl: p.data.imageUrl,
    brand: p.data.brand,
    discount: p.data.discount,
    badge: p.data.badge,
    productSlug: p.data.productSlug || p.slug,
    slug: p.slug
  }));

export interface Props {
  inline?: boolean;
}
const { inline = false } = Astro.props;
---

{promos.length > 0 && (
  <div class:list={[!inline && "py-10 bg-white dark:bg-[#13151d] border-t border-gray-100 dark:border-white/5 transition-colors duration-500"]}>
    <div class:list={["mx-auto", !inline && "container px-4"]}>
      {!inline && (
        <div class="flex items-center justify-between mb-6">
          <div>
            <p class="text-[11px] font-semibold text-indigo-500 dark:text-indigo-400 uppercase tracking-widest mb-1">Ofertas del mes</p>
            <h2 class="text-xl md:text-2xl font-bold text-gray-900 dark:text-white tracking-tight">Promociones imperdibles</h2>
          </div>
          <div class="flex gap-1.5">
            <button class="promo-prev w-8 h-8 flex items-center justify-center rounded-lg border border-gray-200 dark:border-white/10 text-gray-400 hover:text-gray-900 dark:hover:text-white hover:border-gray-300 dark:hover:border-white/20 transition-colors" aria-label="Anterior">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <button class="promo-next w-8 h-8 flex items-center justify-center rounded-lg border border-gray-200 dark:border-white/10 text-gray-400 hover:text-gray-900 dark:hover:text-white hover:border-gray-300 dark:hover:border-white/20 transition-colors" aria-label="Siguiente">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>
      )}

      <div class:list={["promo-swiper", !inline && "pb-4"]}>
        <div class="swiper-wrapper">
          {promos.map((promo) => (
            <div class="swiper-slide">
              {inline ? (
                <a href={`/producto/${promo.productSlug}`} class="group relative block rounded-2xl overflow-hidden bg-white dark:bg-[#181b25] border border-gray-100 dark:border-white/5 hover:border-indigo-200 dark:hover:border-indigo-500/30 hover:shadow-[0_8px_30px_-6px_rgba(99,102,241,0.15)] transition-all duration-500 h-full min-h-[340px]">
                  <!-- Top banner -->
                  <div class="absolute top-0 left-0 right-0 h-9 bg-gradient-to-r from-indigo-500 via-indigo-600 to-purple-600 flex items-center justify-center z-20">
                    <span class="text-[10px] font-bold text-white uppercase tracking-[0.2em]">🔥 Oferta del mes</span>
                  </div>
                  <!-- Discount badge -->
                  {promo.discount && (
                    <div class="absolute top-11 right-3 z-30">
                      <div class="bg-red-500 text-white text-sm font-black px-3 py-1.5 rounded-lg shadow-lg shadow-red-500/30">
                        {promo.discount}
                      </div>
                    </div>
                  )}
                  <!-- Image area -->
                  <div class="flex items-center justify-center pt-12 pb-2 px-6 relative">
                    <img
                      src={promo.imageUrl}
                      alt={promo.name}
                      class="max-h-36 object-contain group-hover:scale-105 transition-transform duration-500 relative z-10"
                      loading="lazy"
                      onerror="this.style.display='none'"
                    />
                  </div>
                  <!-- Content -->
                  <div class="px-5 pb-5 relative z-20">
                    <h3 class="font-semibold text-gray-900 dark:text-white text-sm leading-snug mb-3 line-clamp-2">
                      {promo.name}
                    </h3>
                    <!-- Price block -->
                    <div class="bg-white dark:bg-[#0f1117] border border-gray-200 dark:border-white/10 rounded-xl p-3 shadow-sm">
                      {promo.originalPrice && (
                        <div class="flex items-center gap-2 mb-1">
                          <span class="text-3xl font-black text-gray-300 dark:text-gray-600 line-through decoration-2 leading-none">${Number(promo.originalPrice).toFixed(2)}</span>
                          <span class="text-[10px] font-bold text-red-500 dark:text-red-400 bg-red-50 dark:bg-red-500/10 px-2 py-0.5 rounded-full border border-red-200 dark:border-red-500/20">Ahorra ${(Number(promo.originalPrice) - Number(promo.price)).toFixed(2)}</span>
                        </div>
                      )}
                      <div class="flex items-baseline gap-1">
                        <span class="text-3xl font-black text-indigo-600 dark:text-indigo-400 leading-none">${Number(promo.price).toFixed(2)}</span>
                        <span class="text-[10px] text-gray-400 dark:text-gray-500 font-medium">IVA incluido</span>
                      </div>
                    </div>
                    <!-- CTA -->
                    <div class="mt-3 flex items-center justify-center gap-2 bg-green-600 hover:bg-green-700 text-white text-xs font-semibold py-2.5 rounded-lg transition-colors">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/></svg>
                      Comprar ahora
                    </div>
                  </div>
                </a>
              ) : (
                <a href={`/producto/${promo.productSlug}`} class="group relative flex flex-col bg-white dark:bg-[#181b25] rounded-2xl border border-gray-100 dark:border-white/5 overflow-hidden hover:border-indigo-200 dark:hover:border-indigo-500/30 hover:shadow-[0_8px_30px_-6px_rgba(99,102,241,0.15)] transition-all duration-500 sm:flex-row sm:items-stretch">
                  <div class="flex items-center justify-center p-8 min-h-[200px] sm:w-2/5 relative bg-gray-50 dark:bg-[#12141c]">
                    {promo.discount && (
                      <div class="absolute top-3 right-3 z-20">
                        <div class="bg-red-500 text-white text-[11px] font-black px-2.5 py-1 rounded-lg shadow-lg shadow-red-500/30">
                          {promo.discount}
                        </div>
                      </div>
                    )}
                    <img
                      src={promo.imageUrl}
                      alt={promo.name}
                      class="relative z-10 max-h-40 object-contain group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                      onerror="this.style.display='none'"
                    />
                  </div>
                  <div class="flex flex-col justify-center sm:w-3/5 p-6 relative">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-indigo-500 via-indigo-600 to-purple-600"></div>
                    <span class="text-[10px] font-bold text-indigo-600 dark:text-indigo-400 uppercase tracking-[0.15em] mb-1">🔥 Oferta del mes</span>
                    <h3 class="font-semibold text-gray-900 dark:text-white mb-2 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors leading-snug text-base">
                      {promo.name}
                    </h3>
                    <p class="text-gray-500 dark:text-gray-400 mb-3 line-clamp-2 leading-relaxed text-sm">{promo.description}</p>
                    <div class="bg-white dark:bg-[#0f1117] border border-gray-200 dark:border-white/10 rounded-xl p-3 shadow-sm">
                      <div class="flex items-center gap-2 mb-1">
                        {promo.originalPrice && (
                          <span class="text-3xl font-black text-gray-300 dark:text-gray-600 line-through decoration-2 leading-none">${Number(promo.originalPrice).toFixed(2)}</span>
                        )}
                        {promo.originalPrice && promo.price && (
                          <span class="text-[10px] font-bold text-red-500 dark:text-red-400 bg-red-50 dark:bg-red-500/10 px-2 py-0.5 rounded-full border border-red-200 dark:border-red-500/20">Ahorra ${(Number(promo.originalPrice) - Number(promo.price)).toFixed(2)}</span>
                        )}
                      </div>
                      <span class="font-black text-indigo-600 dark:text-indigo-400 text-3xl leading-none">${Number(promo.price).toFixed(2)}</span>
                      <span class="text-[10px] text-gray-400 dark:text-gray-500 ml-1">IVA incluido</span>
                    </div>
                    <div class="mt-3 flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white text-xs font-semibold py-2.5 px-4 rounded-lg transition-colors w-fit">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/></svg>
                      Comprar ahora
                    </div>
                  </div>
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
)}

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const promoSwiperEl = document.querySelector('.promo-swiper');
    if (!promoSwiperEl || typeof Swiper === 'undefined') return;

    new Swiper('.promo-swiper', {
      loop: true,
      autoplay: { delay: 4000, disableOnInteraction: false },
      slidesPerView: 1,
      spaceBetween: 16,
      navigation: { nextEl: '.promo-next', prevEl: '.promo-prev' },
    });
  });
</script>

<style>
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>
