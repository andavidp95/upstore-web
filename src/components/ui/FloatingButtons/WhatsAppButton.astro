---
// src/components/ui/FloatingButtons/WhatsAppButton.astro
export interface Props {
  phoneNumber?: string;
  message?: string;
  tooltipText?: string;
  position?: 'bottom-right' | 'bottom-left' | 'top-right' | 'top-left';
  className?: string;
}

const {
  phoneNumber = '593987799459',
  message = '',
  tooltipText = '💬 Chat directo • Respuesta inmediata',
  position = 'bottom-right',
  className = ''
} = Astro.props;

// Generar URL de WhatsApp
const whatsappUrl = `https://wa.me/${phoneNumber}${message ? `?text=${encodeURIComponent(message)}` : ''}`;

// Clases de posición
const positionClasses = {
  'bottom-right': 'bottom-6 right-6',
  'bottom-left': 'bottom-6 left-6',
  'top-right': 'top-6 right-6',
  'top-left': 'top-6 left-6'
};

// Clases de tooltip según posición
const tooltipClasses = {
  'bottom-right': 'right-full mr-4',
  'bottom-left': 'left-full ml-4',
  'top-right': 'right-full mr-4',
  'top-left': 'left-full ml-4'
};

// Clases de flecha del tooltip
const arrowClasses = {
  'bottom-right': 'right-0 top-1/2 transform -translate-y-1/2 translate-x-1 border-r border-t',
  'bottom-left': 'left-0 top-1/2 transform -translate-y-1/2 -translate-x-1 border-l border-b',
  'top-right': 'right-0 top-1/2 transform -translate-y-1/2 translate-x-1 border-r border-t',
  'top-left': 'left-0 top-1/2 transform -translate-y-1/2 -translate-x-1 border-l border-b'
};
---

<!-- Botón flotante de WhatsApp -->
<div class={`fixed ${positionClasses[position]} z-50 group ${className}`}>
  <a 
    href={whatsappUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="relative bg-gradient-to-r from-green-500 to-green-600 text-white p-5 rounded-full shadow-2xl hover:shadow-xl transition-all duration-300 transform hover:scale-105 flex items-center justify-center border border-white/10 light:border-green-200/20 hover:shadow-green-500/25"
    aria-label="Contactar por WhatsApp"
  >
    <svg class="w-8 h-8 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24">
      <path d="M20.52 3.49A11.94 11.94 0 0012 0C5.37 0 0 5.37 0 12c0 2.11.55 4.09 1.51 5.81L0 24l6.36-1.49C8.04 23.41 9.98 24 12 24c6.63 0 12-5.37 12-12 0-3.19-1.24-6.19-3.48-8.51zM12 22c-1.78 0-3.5-.46-4.99-1.26l-.36-.21-3.64.85.77-3.58-.23-.37A9.93 9.93 0 012 12C2 6.48 6.48 2 12 2s10 4.48 10 10-4.48 10-10 10zm5.5-7.5c-.3-.15-1.77-.87-2.04-.97-.28-.1-.48-.15-.68.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.27-.47-2.42-1.49-.89-.8-1.49-1.78-1.67-2.08-.18-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.68-1.63-.93-2.23-.24-.58-.49-.5-.68-.51h-.58c-.2 0-.52.08-.79.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.22 3.08c.15.2 2.11 3.22 5.11 4.52.71.31 1.27.49 1.71.63.72.23 1.37.2 1.88.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.29.17-1.42-.07-.12-.27-.2-.57-.35z"/>
    </svg>

    <!-- Badge de disponibilidad -->
    <div class="absolute -top-1 -right-1 w-3 h-3 bg-green-400 rounded-full animate-pulse border-2 border-white shadow-lg">
      <div class="absolute inset-0 bg-green-400 rounded-full animate-ping opacity-75"></div>
    </div>
  </a>

  <!-- Tooltip actualizado para light mode -->
  <span class={`absolute ${tooltipClasses[position]} top-1/2 transform -translate-y-1/2 bg-gray-900 light:bg-white text-white light:text-gray-900 px-4 py-2 rounded-xl text-sm whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 shadow-lg border border-gray-700 light:border-gray-200 pointer-events-none`}>
    {tooltipText}
    <div class={`absolute w-2 h-2 bg-gray-900 light:bg-white rotate-45 ${arrowClasses[position]} border-gray-700 light:border-gray-200`}></div>
  </span>
</div>