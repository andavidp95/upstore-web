---
// src/components/ui/FloatingButtons/StoreButton.astro

export interface Props {
  href?: string;
  tooltipText?: string;
  position?: 'bottom-right' | 'bottom-left' | 'top-right' | 'top-left';
  className?: string;
  badgeColor?: string;
}

const {
  href = '/upstore',
  tooltipText = '⚡ UPStore • UPS y Respaldo Energético • Envío nacional',
  position = 'bottom-left',
  className = '',
  badgeColor = 'blue'
} = Astro.props;

// Clases de posición
const positionClasses = {
  'bottom-right': 'bottom-6 right-6',
  'bottom-left': 'bottom-6 left-6',
  'top-right': 'top-6 right-6',
  'top-left': 'top-6 left-6'
};

// Clases de tooltip según posición
const tooltipClasses = {
  'bottom-right': 'right-full mr-4',
  'bottom-left': 'left-full ml-4',
  'top-right': 'right-full mr-4',
  'top-left': 'left-full ml-4'
};

// Clases de flecha del tooltip
const arrowClasses = {
  'bottom-right': 'right-0 top-1/2 transform -translate-y-1/2 translate-x-1 border-r border-t',
  'bottom-left': 'left-0 top-1/2 transform -translate-y-1/2 -translate-x-1 border-l border-b',
  'top-right': 'right-0 top-1/2 transform -translate-y-1/2 translate-x-1 border-r border-t',
  'top-left': 'left-0 top-1/2 transform -translate-y-1/2 -translate-x-1 border-l border-b'
};

// Colores del badge
const badgeColors = {
  'blue': 'bg-blue-400',
  'green': 'bg-green-400',
  'red': 'bg-red-400',
  'orange': 'bg-orange-400',
  'purple': 'bg-purple-400'
};
---

<!-- Botón flotante del Store -->
<div class={`fixed ${positionClasses[position]} z-50 group ${className}`}>
  <a 
    href={href}
    class="relative bg-gradient-to-r from-blue-500 to-blue-600 text-white p-5 rounded-full shadow-2xl hover:shadow-xl transition-all duration-300 transform hover:scale-105 flex items-center justify-center border border-white/10 hover:shadow-blue-500/25"
    aria-label="Ir a UPStore"
  >
    <svg class="w-8 h-8 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24">
      <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zm10 0c-1.1 0-1.99.9-1.99 2S15.9 22 17 22s2-.9 2-2-.9-2-2-2zM7.16 14.26l.02-.12L7.9 13h8.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49a.996.996 0 00-.87-1.48H5.21l-.94-2H1v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25z"/>
    </svg>

    <!-- Badge de disponibilidad -->
    <div class={`absolute -top-1 -right-1 w-3 h-3 ${badgeColors[badgeColor]} rounded-full animate-pulse border-2 border-white shadow-lg`}>
      <div class={`absolute inset-0 ${badgeColors[badgeColor]} rounded-full animate-ping opacity-75`}></div>
    </div>
  </a>

  <!-- Tooltip -->
  <span class={`absolute ${tooltipClasses[position]} top-1/2 transform -translate-y-1/2 bg-gray-900 text-white px-4 py-2 rounded-xl text-sm whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 shadow-lg border border-gray-700 pointer-events-none`}>
    {tooltipText}
    <div class={`absolute w-2 h-2 bg-gray-900 rotate-45 ${arrowClasses[position]} border-gray-700`}></div>
  </span>
</div>