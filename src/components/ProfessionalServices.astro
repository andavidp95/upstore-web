---
export interface Props {
  services: any[];
  themeColor: string;
  description: string;
}

const { services, themeColor,description } = Astro.props;
---

<section id="services-section" class="py-16 px-4 bg-gray-100 dark:bg-gray-900 relative transition-colors duration-300">
  <div class="container mx-auto">
    <div class="text-center mb-12">
       <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-6 transition-colors duration-300">
        Servicios
        <span class={`bg-gradient-to-r ${themeColor} bg-clip-text text-transparent`}>
          Profesionales
        </span>
      </h2>
      <p class="text-gray-600 dark:text-gray-300 max-w-3xl mx-auto text-sm md:text-base leading-relaxed transition-colors duration-300">
      {description}

      </p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <div class="group relative bg-white/60 dark:bg-gray-800/40 hover:bg-white/80 dark:hover:bg-gray-800/70 backdrop-blur-sm rounded-xl p-6 border border-gray-300/60 dark:border-gray-700/40 hover:border-gray-400/80 dark:hover:border-gray-600/60 transition-all duration-500 hover:scale-[1.02] hover:shadow-xl dark:hover:shadow-lg">
          <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-3 transition-colors duration-300">
            {service.title}
          </h3>
          <p class="text-gray-700 dark:text-gray-300 mb-5 leading-relaxed text-base transition-colors duration-300">
            {service.description}
          </p>
          <ul class="space-y-2">
            {service.features.map((feature) => (
              <li class="text-gray-600 dark:text-gray-400 group-hover:text-gray-700 dark:group-hover:text-gray-300 flex items-center transition-colors duration-300">
                <div class={`w-2 h-2 bg-gradient-to-r ${themeColor} rounded-full mr-3 flex-shrink-0`}></div>
                <span class="text-base leading-relaxed">{feature}</span>
              </li>
            ))}
          </ul>
          <!-- Overlay de hover - diferentes gradientes para cada modo -->
          <div class="absolute inset-0 bg-gradient-to-br from-blue-400/5 to-purple-400/5 dark:from-blue-500/3 dark:to-purple-500/3 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-xl pointer-events-none"></div>
        </div>
      ))}
    </div>
  </div>
</section>