---
export interface Props {
  title: string;
  subtitle: string;
  heroDescription: string;
  starService: {
    title: string;
    logo: string;
  };
  className?: string;
}

const { title, subtitle, heroDescription, starService, className = "" } = Astro.props;
---

<div class={`text-white space-y-8 animate-fade-in px-4 ${className}`}>
  <!-- Logo del servicio -->
  <div class="flex items-center space-x-4 mb-8">
    <img
      src={starService.logo}
      alt={`${title} Logo`}
      class="h-16 sm:h-20 w-auto filter drop-shadow-xl flex-shrink-0"
    />
    <div class="h-12 sm:h-16 w-px bg-white/30 flex-shrink-0"></div>
    <div class="min-w-0">
      <h1 class="text-3xl sm:text-4xl md:text-6xl font-black tracking-tight leading-tight">
        <span class="bg-gradient-to-r from-white to-gray-200 bg-clip-text text-transparent">
          {title}
        </span>
      </h1>
      <h2 class="text-lg sm:text-xl md:text-2xl font-light text-gray-200 mt-3">
        {subtitle}
      </h2>
    </div>
  </div>
  
  <!-- Descripción principal -->
  <div class="space-y-4">
    <p class="text-lg sm:text-xl md:text-2xl leading-relaxed text-gray-100 font-medium break-words">
      {heroDescription}
    </p>
    <div class="flex flex-wrap items-center gap-4 sm:gap-6 text-sm text-gray-300">
      <div class="flex items-center space-x-2">
        <svg class="w-4 h-4 text-green-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
        </svg>
        <span class="whitespace-nowrap">Proyectos personalizados</span>
      </div>
      <div class="flex items-center space-x-2">
        <svg class="w-4 h-4 text-blue-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-6-3a2 2 0 11-4 0 2 2 0 014 0zm-2 4a5 5 0 00-4.546 2.916A5.986 5.986 0 0010 16a5.986 5.986 0 004.546-2.084A5 5 0 0010 11z" clip-rule="evenodd"></path>
        </svg>
        <span class="whitespace-nowrap">Asesoría especializada</span>
      </div>
      <div class="flex items-center space-x-2">
        <svg class="w-4 h-4 text-purple-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
        </svg>
        <span class="whitespace-nowrap">Seguimiento del proyecto</span>
      </div>
    </div>
  </div>
  
  <!-- CTA Principal -->
  <div class="flex flex-col gap-4">
    <button 
      onclick="document.getElementById('contact').scrollIntoView({behavior: 'smooth'})"
      class="w-full bg-white text-gray-900 px-4 sm:px-8 py-4 rounded-2xl text-base sm:text-lg font-black hover:bg-gray-100 transition-all duration-300 transform hover:scale-105 shadow-2xl flex items-center justify-center space-x-3 group"
    >
      <svg class="w-5 h-5 sm:w-6 sm:h-6 group-hover:rotate-12 transition-transform duration-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
      </svg>
      <span class="whitespace-nowrap">Evaluar mi Proyecto</span>
    </button>
    
    <button 
      onclick="document.getElementById('services-section').scrollIntoView({behavior: 'smooth'})"
      class="w-full border-2 border-white/50 text-white px-4 sm:px-8 py-4 rounded-2xl text-base sm:text-lg font-bold hover:bg-white/15 transition-all duration-300 backdrop-blur-sm hover:border-white/80"
    >
      Ver Portafolio de Servicios
    </button>
  </div>
</div>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fade-in {
    animation: fade-in 1s ease-out forwards;
    opacity: 0;
  }
  
  /* Optimización específica para dispositivos problemáticos */
  @media (max-width: 390px) {
    .animate-fade-in {
      animation-duration: 0.8s;
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }
  
  /* iPhone SE y similares */
  @media (max-width: 375px) {
    .animate-fade-in {
      padding-left: 0.75rem;
      padding-right: 0.75rem;
    }
  }
</style>