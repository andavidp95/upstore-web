---
const brandsData = {
  title: "Oficial Partners",
  subtitle: "Distribuidores autorizados de las mejores marcas del mercado mundial. Productos originales con garantía del fabricante y asesoría especializada.",
  categories: [
    {
      name: "UPS",
      brands: [
        { name: "APC by Schneider Electric", logo: "/images/brands/apc.svg" },
        { name: "VERTIV", logo: "/images/brands/vertiv.svg" }
      ]
    },
    {
      name: "Mini UPS",
      brands: [
        { name: "Shanqiu", logo: "/images/brands/shanqiu.png" },
        { name: "HVIKI", logo: "/images/brands/hviki.gif" }
      ]
    }
  ]
};

export interface Props {
  themeColor?: string;
}
const { themeColor = "from-blue-600 to-purple-600" } = Astro.props;
---

<section id="brands-section" class="py-14 bg-white border-t border-gray-100">
  <div class="container mx-auto px-4">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-3">
        {brandsData.title}
      </h2>
      <p class="max-w-2xl mx-auto text-sm text-gray-500 leading-relaxed">
        {brandsData.subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {brandsData.categories.map((category) => (
        <div class="text-center">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">{category.name}</h3>
          <div class="flex justify-center items-center gap-8">
            {category.brands.map((brand) => (
              <div class="flex flex-col items-center gap-2 group">
                <div class="w-28 h-14 flex items-center justify-center rounded-lg bg-gray-50 border border-gray-100 px-4 py-2 group-hover:border-gray-200 group-hover:shadow-sm transition-all">
                  <img
                    src={brand.logo}
                    alt={`${brand.name} logo`}
                    class="max-w-full max-h-full object-contain opacity-70 group-hover:opacity-100 transition-opacity"
                    loading="lazy"
                    onError="this.style.display='none'; this.nextElementSibling.style.display='block';"
                  >
                  <span class="text-sm font-bold text-gray-400 group-hover:text-gray-700 transition-colors hidden">{brand.name.charAt(0)}</span>
                </div>
                <span class="text-xs text-gray-500 font-medium">{brand.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
