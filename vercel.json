{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "astro",

  "cleanUrls": true,
  "trailingSlash": false,

  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.electroipec.com" }],
      "destination": "https://electroipec.com/$1",
      "permanent": true
    }
  ],

  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { 
          "key": "Content-Type", 
          "value": "application/xml; charset=utf-8" 
        },
        { 
          "key": "Cache-Control", 
          "value": "public, max-age=3600, s-maxage=3600" 
        },
        { 
          "key": "X-Robots-Tag", 
          "value": "all" 
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { 
          "key": "Content-Type", 
          "value": "text/plain; charset=utf-8" 
        },
        { 
          "key": "Cache-Control", 
          "value": "public, max-age=3600" 
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { 
          "key": "X-Robots-Tag", 
          "value": "all" 
        },
        { 
          "key": "X-Frame-Options", 
          "value": "DENY" 
        },
        { 
          "key": "X-Content-Type-Options", 
          "value": "nosniff" 
        },
        { 
          "key": "Referrer-Policy", 
          "value": "strict-origin-when-cross-origin" 
        },
        { 
          "key": "Strict-Transport-Security", 
          "value": "max-age=63072000; includeSubDomains; preload" 
        }
      ]
    }
  ]
}